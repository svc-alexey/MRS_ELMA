// << Портал-Юг, Баринов, 2019.04.25 [5.3.3 Запрет на изменение проведённых документов]
// Обработчик события "ПриЗаписи" из подписки на событие ПЛ_ПеремещениеТоваровПриЗаписиОграничениеПоОтправителю
//
// Параметры:
//  Источник - ДокументОбъект.ПеремещениеТоваров - записанный документ
//  Отказ	 - Булево - Стандартный параметр события "ПриЗаписи"
//
Процедура ПЛ_ПеремещениеТоваровПриЗаписиОграничениеПоОтправителюПриЗаписи(Источник, Отказ) Экспорт
	
	Если Источник.ОбменДанными.Загрузка Тогда
		Возврат;
	КонецЕсли; 
	
	// Ограничение нужно только для проведения и изменения проведённых.
	// Пользователь может провести документ, но не может изменять проведённый. И проводить должен иметь возможность только при наличии доступа к складу отправителю.
	// Типовая даёт доступ к документу при наличии доступа к любому из складов документа.
	// Для типовой роли с отменой проведения доступ не ограничиваем.
	
	// Всегда стираем старую запись
	// Если действуют ограничения, у пользователя должно хватить прав на новую запись. Иначе она не нужна.
	УстановитьПривилегированныйРежим(Истина);
	
	Запись = РегистрыСведений.ПЛ_ПеремещениеПоСкладуОтправителю.СоздатьМенеджерЗаписи();
	Запись.Перемещение = Источник.Ссылка;
	Запись.Удалить();
	
	УстановитьПривилегированныйРежим(Ложь);
	
	Если НЕ Источник.Проведен Тогда
		// Важно только проведение документов.
		Возврат;
	КонецЕсли;	
	
	Если ПравоДоступа("ОтменаПроведения", Источник.Метаданные()) Тогда 
		// Если доступна отмена проведения, то ограничение по складу отправителю не действует, работает типовое ограничение доступа.
		Возврат;
	КонецЕсли;	
	
	// При отсутствии доступа к складу запись будет отменена с выдачей сообщения о нарушении прав доступа
	Запись = РегистрыСведений.ПЛ_ПеремещениеПоСкладуОтправителю.СоздатьМенеджерЗаписи();
	Запись.Перемещение = Источник.Ссылка;
	Запись.СкладОтправитель = Источник.СкладОтправитель;
	ПредставлениеСклада = Строка(Источник.СкладОтправитель); // в обработке исключения читать будет уже поздно
	
	Попытка
		Запись.Записать();
	Исключение		
		СообщениеОбОшибке = НСтр("ru = 'Недостаточно прав доступа для проведения документа по складу %1.'") + Символы.ПС + Источник;
		СообщениеОбОшибке = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(СообщениеОбОшибке, ПредставлениеСклада);
		ВызватьИсключение СообщениеОбОшибке;
	КонецПопытки;
	
КонецПроцедуры //>> Портал-Юг, Баринов, 2019.04.25

//<< Портал-Юг, Гладкая Н., 2020.05.28 [Обмен с Elma.Очищаем реквизиты ELMA]			    
Процедура ПЛ_ЗаказНаПеремещениеПриКопированииПриКопировании(Источник, ОбъектКопирования) Экспорт
	РеквизитыДокумента=Новый Структура;
	РеквизитыДокумента.Вставить("ПЛ_UidПотребностиELMA", Неопределено);
	РеквизитыДокумента.Вставить("ПЛ_СозданНаОснованииПотребностиELMA", Неопределено);
	РеквизитыДокумента.Вставить("ПЛ_ПринятоELMA", Неопределено);
	ЗаполнитьЗначенияСвойств(РеквизитыДокумента,Источник);
	Если  РеквизитыДокумента.ПЛ_СозданНаОснованииПотребностиELMA<>Неопределено Тогда
		Источник.ПЛ_СозданНаОснованииПотребностиELMA=Ложь;
	КонецЕсли;
	Если Источник.Товары.Количество()>0 Тогда
		ЗаполнитьЗначенияСвойств(РеквизитыДокумента,Источник.Товары[0]);
		Если  РеквизитыДокумента.ПЛ_ПринятоELMA<>Неопределено Тогда
			Для Каждого Ст Из  Источник.Товары Цикл
				Ст.ПЛ_ПринятоELMA=Ложь;
			КонецЦикла;
		КонецЕсли;
		Если  РеквизитыДокумента.ПЛ_UidПотребностиELMA<>Неопределено Тогда
			Для Каждого Ст Из  Источник.Товары Цикл
				Ст.ПЛ_UidПотребностиELMA="";
			КонецЦикла;
			
		КонецЕсли;

	КонецЕсли;
КонецПроцедуры

