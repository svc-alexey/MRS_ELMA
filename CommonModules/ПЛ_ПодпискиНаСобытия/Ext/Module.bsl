// << MRS #ERP-5011 ДенисламовАД <Adel.Denislamov@mriyaresort.com> 25.04.25, ()
Процедура MRS_ДокументыСписанияЗаказаПовараОбработкаПроведения(Источник, Отказ, Замещение) Экспорт
	
	Если НЕ Отказ Тогда
		Попытка
			Запрос = Новый Запрос;
			Запрос.Текст = 
			"ВЫБРАТЬ
			|	Товары.Номенклатура КАК Номенклатура,
			|	Товары.Характеристика КАК Характеристика,
			|	Товары.Количество КАК Количество,
			|	Товары.MRS_ЗаказПовара КАК MRS_ЗаказПовара,
			|	Товары.Склад КАК Склад
			|ИЗ
			|	Документ.ЗаказКлиента.Товары КАК Товары
			|ГДЕ
			|	НЕ Товары.MRS_ЗаказПовара = &MRS_ЗаказПовара
			|	И Товары.Ссылка = &Ссылка";
			
			Если ТипЗнч(Источник) = Тип("ДокументОбъект.РеализацияТоваровУслуг") Тогда
				Запрос.Текст = СтрЗаменить(Запрос.Текст, "ЗаказКлиента", "РеализацияТоваровУслуг");
			ИначеЕсли ТипЗнч(Источник) = Тип("ДокументОбъект.ПеремещениеТоваров") Тогда
				Запрос.Текст = СтрЗаменить(Запрос.Текст, "ЗаказКлиента", "ПеремещениеТоваров");
				Запрос.Текст = СтрЗаменить(Запрос.Текст, "Товары.Склад", "Товары.Ссылка.СкладПолучатель"); 
			КонецЕсли;
			Запрос.УстановитьПараметр("MRS_ЗаказПовара", Документы.MRS_ЗаказПовара.ПустаяСсылка());
			Запрос.УстановитьПараметр("Ссылка",Источник.Ссылка);
			РезультатЗапроса = Запрос.Выполнить();
			Выборка = РезультатЗапроса.Выбрать();
			Если Выборка.Количество() Тогда
				// регистр MRS_ЗаказыПовара Приход
				Источник.Движения.MRS_ЗаказыПовара.Записывать = Истина;
				Пока Выборка.Следующий() Цикл
					Движение = Источник.Движения.MRS_ЗаказыПовара.Добавить();
					Движение.ВидДвижения = ВидДвиженияНакопления.Расход;
					Движение.Период = Источник.Дата;
					Движение.ЗаказПовара = Выборка.MRS_ЗаказПовара;
					Движение.Номенклатура = Выборка.Номенклатура;
					Движение.Характеристика = Выборка.Характеристика;
					Движение.Склад = Выборка.Склад;
					Движение.Заказано = Выборка.Количество;
				КонецЦикла;
			КонецЕсли;
		Исключение
			
		КонецПопытки;
	КонецЕсли;
	
КонецПроцедуры
// >> MRS #ERP-5011 ДенисламовАД <Adel.Denislamov@mriyaresort.com> 25.04.25, ()

//<< Портал-Юг, Свинцов И.И., 2019.02.13 [5.2.27 Закрытие заказов по алкогольной продукции] 
Процедура ПЛ_РегистрыНакопленияПередЗаписьюПередЗаписью(Источник, Отказ, Замещение) Экспорт
	
	Если Источник.ОбменДанными.Загрузка Тогда
		Возврат;
	КонецЕсли;
	
	КЧ = Новый КвалификаторыЧисла(12,0);
	Массив = Новый Массив;
	Массив.Добавить(Тип("Число"));
	ОписаниеТиповЧ = Новый ОписаниеТипов(Массив, , ,КЧ);
	
	ТЗ = Новый ТаблицаЗначений;
	ТЗ.Колонки.Добавить("Номенклатура", Новый ОписаниеТипов("СправочникСсылка.Номенклатура"));
	ТЗ.Колонки.Добавить("НомерЗаписи", ОписаниеТиповЧ);
	ТЗ.Колонки.Добавить("Склад", Новый ОписаниеТипов("СправочникСсылка.Склады"));
	
	АлкогольнаяПродукцияВоВскрытойТаре = Ложь;	
	ИмяПоля = "";
	ТипДокумента = "";
	ВидДвижения = ""; 
	ОбнулитьКОтгрузке = Ложь;
	УдалитьЗаписиСвободныхОстатков = Ложь;
	ДобавитьЗаписиТоварыКОтгрузке = Ложь;
	
	ТипИсточника = ТипЗнч(Источник);
	ТипРегистратора = ТипЗнч(Источник.Отбор.Регистратор.Значение);
	
	Если ТипИсточника = Тип("РегистрНакопленияНаборЗаписей.ТоварыКОтгрузке") Тогда
		Если ТипРегистратора = Тип("ДокументСсылка.ЗаказНаПеремещение") Тогда
			АлкогольнаяПродукцияВоВскрытойТаре = Истина;
			ИмяПоля = "ДокументОтгрузки";
			ТипДокумента = "ДокументСсылка.ЗаказНаПеремещение";
			ВидДвижения = ВидДвиженияНакопления.Приход;
			ОбнулитьКОтгрузке = Истина;
		ИначеЕсли  ТипРегистратора = Тип("ДокументСсылка.ПеремещениеТоваров") Тогда
			ДобавитьЗаписиТоварыКОтгрузке = Истина;
			ИмяПоля = "ДокументОтгрузки";
			ТипДокумента = "ДокументСсылка.ЗаказНаПеремещение";
			ВидДвижения = ВидДвиженияНакопления.Расход;	
		Иначе
			Возврат;
		КонецЕсли;	
		
	ИначеЕсли ТипИсточника = Тип("РегистрНакопленияНаборЗаписей.ЗаказыНаПеремещение") Тогда
		Если ТипРегистратора = Тип("ДокументСсылка.ПеремещениеТоваров") Тогда
			ИмяПоля = "ЗаказНаПеремещение";
			ТипДокумента = "ДокументСсылка.ЗаказНаПеремещение";
			//<< Портал-Юг, Баринов, 2019.09.20 [5.2.27 Закрытие заказов по алкогольной продукции]
			// Приходные движения в этом случае тоже нужно обработать - это строки сверх заказа с ресурсом "К оформлению".
			// ВидДвижения = ВидДвиженияНакопления.Расход;	
			//>> Портал-Юг, Баринов, 2019.09.20
		Иначе
			Возврат;
		КонецЕсли;	
		
	ИначеЕсли ТипИсточника = Тип("РегистрНакопленияНаборЗаписей.ЗаказыПоставщикам") Тогда
		Если ТипРегистратора = Тип("ДокументСсылка.ЗаказПоставщику") Тогда
			ИмяПоля = "ЗаказПоставщику";
			ТипДокумента = "ДокументСсылка.ЗаказПоставщику";
			ВидДвижения = ВидДвиженияНакопления.Приход; 
		ИначеЕсли ТипРегистратора = Тип("ДокументСсылка.ПриобретениеТоваровУслуг") Тогда
			ИмяПоля = "ЗаказПоставщику";
			ТипДокумента = "ДокументСсылка.ЗаказПоставщику";
			//<< Портал-Юг, Баринов, 2019.09.20 [5.2.27 Закрытие заказов по алкогольной продукции]
			// Приходные движения в этом случае тоже нужно обработать - это строки сверх заказа с ресурсом "К оформлению".
			// ВидДвижения = ВидДвиженияНакопления.Расход;	
			//>> Портал-Юг, Баринов, 2019.09.20
		Иначе
			Возврат;
		КонецЕсли;	
		
	ИначеЕсли ТипИсточника = Тип("РегистрНакопленияНаборЗаписей.ТоварыКПоступлению") Тогда
		Если ТипРегистратора = Тип("ДокументСсылка.ПеремещениеТоваров") Тогда
			ИмяПоля = "ДокументПоступления";
			ТипДокумента  = "ДокументСсылка.ЗаказНаПеремещение";
			ВидДвижения = "";
		ИначеЕсли ТипРегистратора = Тип("ДокументСсылка.ЗаказПоставщику") Тогда
			ИмяПоля = "ДокументПоступления";
			ТипДокумента  = "ДокументСсылка.ЗаказПоставщику";
			ВидДвижения = "";
		ИначеЕсли ТипРегистратора = Тип("ДокументСсылка.ПриобретениеТоваровУслуг") Тогда
			ИмяПоля = "ДокументПоступления";
			ТипДокумента = "ДокументСсылка.ЗаказПоставщику";
			ВидДвижения = ВидДвиженияНакопления.Расход;
		Иначе
			Возврат;
		КонецЕсли;
		
	Иначе
		Возврат;	
	КонецЕсли;
	
	СтрПараметров = Новый Структура;
	СтрПараметров.Вставить("Источник", Источник);
	СтрПараметров.Вставить("ИмяПоля", ИмяПоля);
	СтрПараметров.Вставить("ТипДокумента", ТипДокумента);
	СтрПараметров.Вставить("ВидДвижения", ВидДвижения);
	
	ДобавитьСтрокиВТЗ(ТЗ, СтрПараметров);
	
	Если ТЗ.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;	
	
	КоллекцияРесурсовРН = Источник.Метаданные().Ресурсы;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ВЫРАЗИТЬ(НаборЗаписей.Номенклатура КАК Справочник.Номенклатура) КАК Номенклатура,
	|	НаборЗаписей.НомерЗаписи КАК НомерЗаписи,
	|	ВЫРАЗИТЬ(НаборЗаписей.Склад КАК Справочник.Склады) КАК Склад
	|ПОМЕСТИТЬ ВТ_НаборЗаписей
	|ИЗ
	|	&НаборЗаписей КАК НаборЗаписей
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ_НаборЗаписей.Номенклатура КАК Номенклатура,
	|	ВТ_НаборЗаписей.Номенклатура.ОбъемДАЛ КАК ОбъемДАЛ,
	|	ВТ_НаборЗаписей.Номенклатура.ПЛ_НоменклатураВоВскрытойТаре КАК НоменклатураВоВскрытойТаре,
	|	ВТ_НаборЗаписей.НомерЗаписи КАК НомерЗаписи,
	|	ВТ_НаборЗаписей.Склад КАК Склад,
	|	ВТ_НаборЗаписей.Склад.ИспользоватьОрдернуюСхемуПриОтгрузке КАК СкладИспользоватьОрдернуюСхемуПриОтгрузке,
	|	ВТ_НаборЗаписей.Склад.ДатаНачалаОрдернойСхемыПриОтгрузке КАК СкладДатаНачалаОрдернойСхемыПриОтгрузке,
	|	ВТ_НаборЗаписей.Номенклатура.Представление КАК НомПредставление
	|ИЗ
	|	ВТ_НаборЗаписей КАК ВТ_НаборЗаписей
	|ГДЕ
	|	ВТ_НаборЗаписей.Номенклатура.АлкогольнаяПродукция
	|	И ВТ_НаборЗаписей.Номенклатура.АлкогольнаяПродукцияВоВскрытойТаре = &АлкогольнаяПродукцияВоВскрытойТаре
	|	И НЕ ВТ_НаборЗаписей.Номенклатура.ПЛ_ИспользуетсяВЗаказах
	|	И ВТ_НаборЗаписей.Склад.ПЛ_ИспользоватьПодменуАлкогольнойПродукции";
	
	Запрос.УстановитьПараметр("АлкогольнаяПродукцияВоВскрытойТаре", АлкогольнаяПродукцияВоВскрытойТаре);
	Запрос.УстановитьПараметр("НаборЗаписей", ТЗ);
	
	РезультатЗапроса = Запрос.Выполнить();
	ВДЗ = РезультатЗапроса.Выбрать();
	
	Пока ВДЗ.Следующий() Цикл
		
		Если ОбнулитьКОтгрузке Тогда
			Если ВДЗ.СкладИспользоватьОрдернуюСхемуПриОтгрузке И ВДЗ.СкладДатаНачалаОрдернойСхемыПриОтгрузке <= Источник.ДополнительныеСвойства.ДатаРегистратора Тогда
				Источник[ВДЗ.НомерЗаписи].КОтгрузке = 0;
			КонецЕсли;
		Иначе
			
			Если НЕ ЗначениеЗаполнено(ВДЗ.НоменклатураВоВскрытойТаре) Тогда
				Продолжить;
			КонецЕсли;
			
			Если ВДЗ.ОбъемДАЛ = 0 Тогда
				
				ТекстСообщения = НСтр("ru='Не указан объем ДАЛ для %НомПредставление%'");
				ТекстСообщения = СтрЗаменить(ТекстСообщения,"%НомПредставление%", ВДЗ.НомПредставление);
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения, ВДЗ.Номенклатура, , , Отказ);   
				
			Иначе
				
				Если Отказ Тогда
					Продолжить;
				КонецЕсли;
				
				// Добавляем записи для формирования потребности в расходных ордерах
				// Только для перемещений со склада с ордерной отгрузкой и флагом подмены алкогольной продукции
				Если ДобавитьЗаписиТоварыКОтгрузке Тогда
					
					Если ВДЗ.СкладИспользоватьОрдернуюСхемуПриОтгрузке И ВДЗ.СкладДатаНачалаОрдернойСхемыПриОтгрузке <= Источник.ДополнительныеСвойства.ДатаРегистратора Тогда
						НоваяЗапись = Источник.Добавить();
						ЗаполнитьЗначенияСвойств(НоваяЗапись, Источник[ВДЗ.НомерЗаписи]);
						НоваяЗапись.Регистратор = Источник.Отбор.Регистратор;
						НоваяЗапись.ВидДвижения = ВидДвиженияНакопления.Приход; 
						НоваяЗапись.КОтгрузке = Источник[ВДЗ.НомерЗаписи].КОформлению;
						НоваяЗапись.КОформлению = 0;
					КонецЕсли;
					
				КонецЕсли;
				
				Источник[ВДЗ.НомерЗаписи].Номенклатура = ВДЗ.НоменклатураВоВскрытойТаре;
				
				Для каждого ИмяРесурса Из КоллекцияРесурсовРН Цикл
					Источник[ВДЗ.НомерЗаписи][ИмяРесурса.Имя] = Источник[ВДЗ.НомерЗаписи][ИмяРесурса.Имя] * ВДЗ.ОбъемДАЛ *10;
				КонецЦикла;
				
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры //>> Портал-Юг, Свинцов И.И. 2019.02.13

//<< Портал-Юг, Свинцов И.И., 2019.02.20 [5.2.27 Закрытие заказов по алкогольной продукции] 
Процедура ПЛ_ДокументыДляЗаказовАлкоголяОбработкаЗаполненияОбработкаПроверкиЗаполнения(Источник, Отказ, ПроверяемыеРеквизиты) Экспорт
	
	Запрос = Новый Запрос;
	
	Если ТипЗнч(Источник) = Тип("ДокументОбъект.ЗаказПоставщику") Тогда
		
		//<< Портал-Юг, Баринов, 2019.09.20 [5.2.27 Закрытие заказов по алкогольной продукции]
		//Запрос.УстановитьПараметр("Товары", Источник.Товары.Выгрузить(, "Номенклатура, Склад"));
		Запрос.УстановитьПараметр("Товары", Источник.Товары.Выгрузить(Новый Структура("Отменено", Ложь), "Номенклатура, Склад"));
		//>> Портал-Юг, Баринов, 2019.09.20
				
	ИначеЕсли ТипЗнч(Источник) = Тип("ДокументОбъект.ЗаказНаПеремещение") Тогда
		
		Товары = Новый ТаблицаЗначений;
		Товары.Колонки.Добавить("Номенклатура", Новый ОписаниеТипов("СправочникСсылка.Номенклатура")); 
		Товары.Колонки.Добавить("Склад", Новый ОписаниеТипов("СправочникСсылка.Склады"));
		
		Для каждого СтрТаблицы Из Источник.Товары Цикл
			//<< Портал-Юг, Баринов, 2019.09.20 [5.2.27 Закрытие заказов по алкогольной продукции]
			Если СтрТаблицы.Отменено Тогда 
				Продолжить;	
			КонецЕсли;	
			//>> Портал-Юг, Баринов, 2019.09.20
			стрТовары = Товары.Добавить();
			стрТовары.Номенклатура = СтрТаблицы.Номенклатура; 
			стрТовары.Склад = Источник.СкладОтправитель;              
		КонецЦикла; 
		
		Запрос.УстановитьПараметр("Товары", Товары);
		
	Иначе
		Возврат;
	КонецЕсли;	
	
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ВЫРАЗИТЬ(Товары.Номенклатура КАК Справочник.Номенклатура) КАК Номенклатура,
	|	ВЫРАЗИТЬ(Товары.Склад КАК Справочник.Склады) КАК Склад
	|ПОМЕСТИТЬ ВТ_Товары
	|ИЗ
	|	&Товары КАК Товары
	|;
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ_Товары.Номенклатура КАК Номенклатура,
	|	ВТ_Товары.Номенклатура.Представление КАК НомПредставление,
	|	ВТ_Товары.Склад.Представление КАК СкладПредставление
	|ИЗ
	|	ВТ_Товары КАК ВТ_Товары
	|ГДЕ
	|	ВТ_Товары.Номенклатура.АлкогольнаяПродукция
	|	И НЕ ВТ_Товары.Номенклатура.ПЛ_ИспользуетсяВЗаказах
	|	И НЕ ВТ_Товары.Номенклатура.АлкогольнаяПродукцияВоВскрытойТаре
	|	И ВТ_Товары.Склад.ПЛ_ИспользоватьПодменуАлкогольнойПродукции"; 
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВДЗ = РезультатЗапроса.Выбрать();
	Пока ВДЗ.Следующий() Цикл
		
		ТекстСообщения = НСтр("ru='Номенклатуру %НомПредставление% нельзя использовать на складе %СкладПредставление%'");
		ТекстСообщения = СтрЗаменить(ТекстСообщения,"%НомПредставление%", ВДЗ.НомПредставление);
		ТекстСообщения = СтрЗаменить(ТекстСообщения,"%СкладПредставление%", ВДЗ.СкладПредставление);
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения, ВДЗ.Номенклатура, , , Отказ);
		
	КонецЦикла;
	
КонецПроцедуры //>> Портал-Юг, Свинцов И.И., 2019.02.20

//<< Портал-Юг, Свинцов И.И., 2019.02.26 [5.2.29 Автоматическая генерация серий и заполнение документа «Приобретение товаров и услуг» по данны] 
