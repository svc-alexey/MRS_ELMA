Процедура MRS_ОбработкаПроведенияПТиУ(Источник, Отказ) Экспорт
	
	// регистр КГМ_Прослеживаемость
	Движения = Источник.Движения;
	
	Движения.алкАкцизПоПриобретеннымЦенностям.Записывать = Истина;
	
	Если ТипЗнч(Источник) = Тип("ДокументОбъект.ПриобретениеТоваровУслуг") Тогда
				
		//Если СокрЛП(Год(Дата))="2 021" Тогда 
		//	Коэф=0.031;  
		//Иначе 
			Коэф = 0.032; 
		//КонецЕсли;
		
		Для Каждого ТекСтрокаТовары Из Источник.Товары Цикл   
			
			Если ТекСтрокаТовары.Номенклатура.ВидНоменклатуры = Справочники.ВидыНоменклатуры.НайтиПоНаименованию("Виноград") Тогда
			
				// Расход ====================================================================================================================
				Движение = Движения.алкАкцизПоПриобретеннымЦенностям.Добавить();  
				
				Движение.Активность		= Истина;
				Движение.Период			= Источник.Дата; 
				Движение.Организация	= Источник.Организация;  
				
				Если Источник.Договор.Пустая() = Истина Тогда
							
					Движение.ДоговорКонтрагента = Справочники.ДоговорыКонтрагентов.НайтиПоРеквизиту("Номер","1-Виноград"); 
				
				Иначе 
					
					Движение.ДоговорКонтрагента = Источник.Договор;  
				
			    КонецЕсли; 	 
			
			
				Движение.Сделка = Источник.ссылка;   
					
				// Измерения 
				Движение.СерияНоменклатуры	= ТекСтрокаТовары.Серия;    
				Движение.Номенклатура		= ТекСтрокаТовары.Номенклатура;

				Движение.СостояниеСырья		= Перечисления.алкСостоянияПодакцизногоСырья.ВМестахХранения;
