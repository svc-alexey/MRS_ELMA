			Движение.КорПодразделение	= Источник.Подразделение;
			//Движение.Контрагент			= Контрагент;
			Движение.СтоимостьОплачено	= 0;
			Движение.КоличествоДоп		= ТекСтрокаТовары.Количество;
			
			Движение.ТехнологическаяОперация		= Справочники.КГМ_ТехнологическиеОперацииВиноделия.ПеремещениеВРозницу;		
			Движение.ВидОперацииДляПрослеживаемости	= Перечисления.ВидыОперацийДляПрослеживаемости.ПоставкаАПРознице;
			Движение.ГУИДЗаписи = Новый УникальныйИдентификатор();
		КонецЦикла;
		
	Иначе
		// другие документы не добавлены в Источники подписки
	КонецЕсли;	
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

//<< Портал-Юг, Свинцов И.И., 2019.02.18 [5.2.27 Закрытие заказов по алкогольной продукции]
Процедура ДобавитьСтрокиВТЗ(ТЗ, СтрПараметров)
	
	НомерЗаписи = -1;
	
	Если СтрПараметров.Источник.Метаданные().Реквизиты.Найти("Склад") <> Неопределено Тогда
		Склад = Справочники.Склады.ПустаяСсылка();
	ИначеЕсли СтрПараметров.Источник.Отбор.Регистратор.Значение.Метаданные().Реквизиты.Найти("Склад") <> Неопределено Тогда 
		Склад = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(СтрПараметров.Источник.Отбор.Регистратор.Значение, "Склад");
	ИначеЕсли СтрПараметров.Источник.Отбор.Регистратор.Значение.Метаданные().Реквизиты.Найти("СкладОтправитель") <> Неопределено Тогда
		Склад = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(СтрПараметров.Источник.Отбор.Регистратор.Значение, "СкладОтправитель");
	Иначе
		Возврат;
	КонецЕсли;
	
	Для каждого Запись Из СтрПараметров.Источник Цикл
		
		НомерЗаписи = НомерЗаписи + 1;
		Если ЗначениеЗаполнено(СтрПараметров.ВидДвижения) Тогда
			Если Запись.ВидДвижения <> СтрПараметров.ВидДвижения Тогда
				Продолжить;
			КонецЕсли;
		КонецЕсли;	
		
		Если ЗначениеЗаполнено(СтрПараметров.ИмяПоля) Тогда
			Если ТипЗнч(Запись[СтрПараметров.ИмяПоля]) <>  Тип(СтрПараметров.ТипДокумента) Тогда
				Продолжить;	
			КонецЕсли;	
		КонецЕсли;
		
		СтрокаТЗ = ТЗ.Добавить();
		СтрокаТЗ.Номенклатура = Запись.Номенклатура;
		СтрокаТЗ.НомерЗаписи =  НомерЗаписи;
		СтрокаТЗ.Склад =  ?(ЗначениеЗаполнено(Склад), Склад, Запись.Склад);
		
	КонецЦикла; 
	
КонецПроцедуры //>> Портал-Юг, Свинцов И.И., 2019.02.18

Процедура ОбработкаПроведения_ЗаказПоставщику(Источник, Отказ, РежимПроведения)
	
	Если Источник.Статус = Перечисления.СтатусыЗаказовПоставщикам.Согласован Тогда
		
		ДвиженияЗаказыПоставщикам=Источник.Движения.ЗаказыПоставщикам;
	 	ДвиженияЗаказыПоставщикам.Прочитать();

		ТЗДвиженияЗаказыПоставщикам = Новый ТаблицаЗначений;
		ТЗДвиженияЗаказыПоставщикам = ДвиженияЗаказыПоставщикам.Выгрузить();
	
		Источник.ОбменДанными.Загрузка = Истина;
		ДвиженияЗаказыПоставщикам.ОбменДанными.Загрузка = Истина;
		Для каждого стр Из ТзДвиженияЗаказыПоставщикам Цикл
		    стр.КОформлению = стр.Заказано;
		КонецЦикла; 
		ДвиженияЗаказыПоставщикам.Загрузить(ТЗДвиженияЗаказыПоставщикам);
		ДвиженияЗаказыПоставщикам.Записать(Истина);
	КонецЕсли; 
	
КонецПроцедуры	
//<< ПорталЮг, КондрашихинИА, 11.11.2024 [Автоматическое закрытие заказов поставщику и заказов на перемещение]
//
Процедура докЗаказыОбновитьОчередьЗаказовКЗакрытиюПриЗаписи(Источник, Отказ, РежимПроведения) Экспорт
	
	ЗаписьНеТребуется = Источник.ОбменДанными.Загрузка 
	ИЛИ Отказ
	ИЛИ Источник = Неопределено
	ИЛИ НЕ Источник.ДополнительныеСвойства.ПроведениеДокументов.СвойстваДокумента.РежимЗаписи = РежимЗаписиДокумента.Проведение
	ИЛИ Источник.ДополнительныеСвойства.Свойство("ПЛ_РегламентноеЗаданиеЗакрытиеЗаказов"); 
	
	Если ЗаписьНеТребуется Тогда  
		Возврат;
	КонецЕсли;
	
	РегистрыСведений.ПЛ_ОчередьЗаказовКЗакрытию.ДобавитьЗаказВОчередь(Источник.Ссылка);

КонецПроцедуры

Процедура приобретениеТоваровУслугПоставитьСтатусЗаказаПоставщикуЕЛМАВОчередьПриЗаписи(Источник, Отказ) Экспорт

	Если Источник = Неопределено Тогда
		Возврат;
	КонецЕсли;

	Если Отказ Тогда
		Возврат;
	КонецЕсли;

	Если Источник.ОбменДанными.Загрузка Тогда
		Возврат;
	КонецЕсли;

	Если НЕ Источник.Проведен Тогда
		Возврат;
	КонецЕсли;

	Если НЕ Источник.ПоступлениеПоЗаказам Тогда
		Возврат;
	КонецЕсли;

	Попытка

		MRS_ИнтеграцияЕЛМАСервер.ПоставитьПриобретениеВОчередьСтатусаЗаказаПоставщикуЕЛМА(Источник);

	Исключение

		ОписаниеОшибкиЕЛМА = ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
		ТекстОшибкиЕЛМА = СтрШаблон(
			"Ошибка постановки ПТУ в очередь отправки статуса заказа поставщику в ЕЛМА при записи документа: %1",
			ОписаниеОшибкиЕЛМА);
		ЗаписьЖурналаРегистрации("MRS.ЕЛМА", УровеньЖурналаРегистрации.Ошибка, , , ТекстОшибкиЕЛМА);

	КонецПопытки;

КонецПроцедуры

#КонецОбласти
