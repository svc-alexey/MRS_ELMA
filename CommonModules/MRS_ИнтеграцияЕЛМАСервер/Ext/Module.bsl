	|ПОМЕСТИТЬ ВТ_ЗакупкиПредМесяцТолькоНоменклатура
	|ИЗ
	|	РегистрНакопления.Закупки КАК Закупки
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
	|			Закупки.АналитикаУчетаНоменклатуры.Номенклатура КАК Номенклатура,
	|			МАКСИМУМ(Закупки.Период) КАК Период
	|		ИЗ
	|			РегистрНакопления.Закупки КАК Закупки
	|				ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ_Номенклатура КАК ВТ_Номенклатура
	|				ПО Закупки.АналитикаУчетаНоменклатуры.Номенклатура = ВТ_Номенклатура.Номенклатура
	|		ГДЕ
	|			Закупки.Стоимость <> 0
	|			И Закупки.Количество <> 0
	|			И Закупки.Регистратор ССЫЛКА Документ.ПриобретениеТоваровУслуг
	|			И Закупки.Период >= НАЧАЛОПЕРИОДА(ДОБАВИТЬКДАТЕ(&ТекущаяДата, МЕСЯЦ, -1), МЕСЯЦ)
	|			И Закупки.Период < ДОБАВИТЬКДАТЕ(КОНЕЦПЕРИОДА(ДОБАВИТЬКДАТЕ(&ТекущаяДата, МЕСЯЦ, -1), МЕСЯЦ), СЕКУНДА, 1)
	|		
	|		СГРУППИРОВАТЬ ПО
	|			Закупки.АналитикаУчетаНоменклатуры.Номенклатура) КАК ПоследниеЗакупки
	|		ПО Закупки.АналитикаУчетаНоменклатуры.Номенклатура = ПоследниеЗакупки.Номенклатура
	|			И Закупки.Период = ПоследниеЗакупки.Период
	|ГДЕ
	|	Закупки.Стоимость <> 0
	|	И Закупки.Количество <> 0
	|	И Закупки.Регистратор ССЫЛКА Документ.ПриобретениеТоваровУслуг
	|	И Закупки.Период >= НАЧАЛОПЕРИОДА(ДОБАВИТЬКДАТЕ(&ТекущаяДата, МЕСЯЦ, -1), МЕСЯЦ)
	|	И Закупки.Период < ДОБАВИТЬКДАТЕ(КОНЕЦПЕРИОДА(ДОБАВИТЬКДАТЕ(&ТекущаяДата, МЕСЯЦ, -1), МЕСЯЦ), СЕКУНДА, 1)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	питМеню.Номенклатура КАК Номенклатура,
	|	питМеню.MRS_СтавкаНДС КАК MRS_СтавкаНДС,
	|	ВТ_Наценка.ПроцентНаценки КАК ПроцентНаценки,
	|	ВТ_Наценка.Организация КАК Организация,
	|	ВТ_Наценка.СкладРеализации КАК СкладРеализации,
	|	ВЫБОР
	|		КОГДА ВТ_СтоимостьПоСкладу.Стоимость ЕСТЬ НЕ NULL 
	|			ТОГДА ВТ_СтоимостьПоСкладу.Стоимость
	|		КОГДА ВТ_СтоимостьПоПодразделению.Стоимость ЕСТЬ НЕ NULL 
	|			ТОГДА ВТ_СтоимостьПоПодразделению.Стоимость
	|		КОГДА ВТ_СтоимостьПоОрганизации.Стоимость ЕСТЬ НЕ NULL 
	|			ТОГДА ВТ_СтоимостьПоОрганизации.Стоимость
	|		КОГДА ВТ_ЗакупкиТекМесяцСклад.Стоимость ЕСТЬ НЕ NULL 
	|			ТОГДА ВТ_ЗакупкиТекМесяцСклад.Стоимость
	|		КОГДА ВТ_ЗакупкиТекМесяцПодразделение.Стоимость ЕСТЬ НЕ NULL 
	|			ТОГДА ВТ_ЗакупкиТекМесяцПодразделение.Стоимость
	|		КОГДА ВТ_ЗакупкиТекМесяцОрганизация.Стоимость ЕСТЬ НЕ NULL 
	|			ТОГДА ВТ_ЗакупкиТекМесяцОрганизация.Стоимость
	|		КОГДА ВТ_ЗакупкиПредМесяцСклад.Стоимость ЕСТЬ НЕ NULL 
	|			ТОГДА ВТ_ЗакупкиПредМесяцСклад.Стоимость
	|		КОГДА ВТ_ЗакупкиПредМесяцПодразделение.Стоимость ЕСТЬ НЕ NULL 
	|			ТОГДА ВТ_ЗакупкиПредМесяцПодразделение.Стоимость
	|		КОГДА ВТ_ЗакупкиПредМесяцОрганизация.Стоимость ЕСТЬ НЕ NULL 
	|			ТОГДА ВТ_ЗакупкиПредМесяцОрганизация.Стоимость
	|		КОГДА ВТ_СтоимостьТолькоНоменклатура.Стоимость ЕСТЬ НЕ NULL 
	|			ТОГДА ВТ_СтоимостьТолькоНоменклатура.Стоимость
	|		КОГДА ВТ_ЗакупкиТекМесяцТолькоНоменклатура.Стоимость ЕСТЬ НЕ NULL 
	|			ТОГДА ВТ_ЗакупкиТекМесяцТолькоНоменклатура.Стоимость
	|		КОГДА ВТ_ЗакупкиПредМесяцТолькоНоменклатура.Стоимость ЕСТЬ НЕ NULL 
	|			ТОГДА ВТ_ЗакупкиПредМесяцТолькоНоменклатура.Стоимость
	|		ИНАЧЕ 0
	|	КОНЕЦ КАК Стоимость,
	|	ВЫБОР
	|		КОГДА ВТ_СтоимостьПоСкладу.Стоимость ЕСТЬ НЕ NULL 
	|			ТОГДА ВТ_СтоимостьПоСкладу.Стоимость * (1 + ЕСТЬNULL(питМеню.MRS_СтавкаНДС.Ставка, 0) / 100) * (1 + ЕСТЬNULL(ВТ_Наценка.ПроцентНаценки, 0) / 100)
	|		КОГДА ВТ_СтоимостьПоПодразделению.Стоимость ЕСТЬ НЕ NULL 
	|			ТОГДА ВТ_СтоимостьПоПодразделению.Стоимость * (1 + ЕСТЬNULL(питМеню.MRS_СтавкаНДС.Ставка, 0) / 100) * (1 + ЕСТЬNULL(ВТ_Наценка.ПроцентНаценки, 0) / 100)
	|		КОГДА ВТ_СтоимостьПоОрганизации.Стоимость ЕСТЬ НЕ NULL 
	|			ТОГДА ВТ_СтоимостьПоОрганизации.Стоимость * (1 + ЕСТЬNULL(питМеню.MRS_СтавкаНДС.Ставка, 0) / 100) * (1 + ЕСТЬNULL(ВТ_Наценка.ПроцентНаценки, 0) / 100)
	|		КОГДА ВТ_ЗакупкиТекМесяцСклад.Стоимость ЕСТЬ НЕ NULL 
	|			ТОГДА ВТ_ЗакупкиТекМесяцСклад.Стоимость * (1 + ЕСТЬNULL(питМеню.MRS_СтавкаНДС.Ставка, 0) / 100) * (1 + ЕСТЬNULL(ВТ_Наценка.ПроцентНаценки, 0) / 100)
	|		КОГДА ВТ_ЗакупкиТекМесяцПодразделение.Стоимость ЕСТЬ НЕ NULL 
	|			ТОГДА ВТ_ЗакупкиТекМесяцПодразделение.Стоимость * (1 + ЕСТЬNULL(питМеню.MRS_СтавкаНДС.Ставка, 0) / 100) * (1 + ЕСТЬNULL(ВТ_Наценка.ПроцентНаценки, 0) / 100)
	|		КОГДА ВТ_ЗакупкиТекМесяцОрганизация.Стоимость ЕСТЬ НЕ NULL 
	|			ТОГДА ВТ_ЗакупкиТекМесяцОрганизация.Стоимость * (1 + ЕСТЬNULL(питМеню.MRS_СтавкаНДС.Ставка, 0) / 100) * (1 + ЕСТЬNULL(ВТ_Наценка.ПроцентНаценки, 0) / 100)
	|		КОГДА ВТ_ЗакупкиПредМесяцСклад.Стоимость ЕСТЬ НЕ NULL 
	|			ТОГДА ВТ_ЗакупкиПредМесяцСклад.Стоимость * (1 + ЕСТЬNULL(питМеню.MRS_СтавкаНДС.Ставка, 0) / 100) * (1 + ЕСТЬNULL(ВТ_Наценка.ПроцентНаценки, 0) / 100)
	|		КОГДА ВТ_ЗакупкиПредМесяцПодразделение.Стоимость ЕСТЬ НЕ NULL 
	|			ТОГДА ВТ_ЗакупкиПредМесяцПодразделение.Стоимость * (1 + ЕСТЬNULL(питМеню.MRS_СтавкаНДС.Ставка, 0) / 100) * (1 + ЕСТЬNULL(ВТ_Наценка.ПроцентНаценки, 0) / 100)
	|		КОГДА ВТ_ЗакупкиПредМесяцОрганизация.Стоимость ЕСТЬ НЕ NULL 
	|			ТОГДА ВТ_ЗакупкиПредМесяцОрганизация.Стоимость * (1 + ЕСТЬNULL(питМеню.MRS_СтавкаНДС.Ставка, 0) / 100) * (1 + ЕСТЬNULL(ВТ_Наценка.ПроцентНаценки, 0) / 100)
	|		КОГДА ВТ_СтоимостьТолькоНоменклатура.Стоимость ЕСТЬ НЕ NULL 
	|			ТОГДА ВТ_СтоимостьТолькоНоменклатура.Стоимость * (1 + ЕСТЬNULL(питМеню.MRS_СтавкаНДС.Ставка, 0) / 100) * (1 + ЕСТЬNULL(ВТ_Наценка.ПроцентНаценки, 0) / 100)
	|		КОГДА ВТ_ЗакупкиТекМесяцТолькоНоменклатура.Стоимость ЕСТЬ НЕ NULL 
	|			ТОГДА ВТ_ЗакупкиТекМесяцТолькоНоменклатура.Стоимость * (1 + ЕСТЬNULL(питМеню.MRS_СтавкаНДС.Ставка, 0) / 100) * (1 + ЕСТЬNULL(ВТ_Наценка.ПроцентНаценки, 0) / 100)
	|		КОГДА ВТ_ЗакупкиПредМесяцТолькоНоменклатура.Стоимость ЕСТЬ НЕ NULL 
	|			ТОГДА ВТ_ЗакупкиПредМесяцТолькоНоменклатура.Стоимость * (1 + ЕСТЬNULL(питМеню.MRS_СтавкаНДС.Ставка, 0) / 100) * (1 + ЕСТЬNULL(ВТ_Наценка.ПроцентНаценки, 0) / 100)
	|		ИНАЧЕ 0
	|	КОНЕЦ КАК СтоимостьСНаценкой
	|ПОМЕСТИТЬ ВТ_РасчетНаценки
	|ИЗ
	|	Справочник.питМеню КАК питМеню
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_Наценка КАК ВТ_Наценка
	|		ПО питМеню.Владелец = ВТ_Наценка.ВидМеню
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_СтоимостьПоСкладу КАК ВТ_СтоимостьПоСкладу
	|		ПО питМеню.Номенклатура = ВТ_СтоимостьПоСкладу.Номенклатура
	|			И (ВТ_Наценка.Организация = ВТ_СтоимостьПоСкладу.Организация)
	|			И (ВТ_Наценка.СкладРеализации = ВТ_СтоимостьПоСкладу.СкладРеализации)
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_СтоимостьПоПодразделению КАК ВТ_СтоимостьПоПодразделению
	|		ПО питМеню.Номенклатура = ВТ_СтоимостьПоПодразделению.Номенклатура
	|			И (ВТ_Наценка.Организация = ВТ_СтоимостьПоПодразделению.Организация)
	|			И (ВТ_Наценка.Подразделение = ВТ_СтоимостьПоПодразделению.Подразделение)
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_СтоимостьПоОрганизации КАК ВТ_СтоимостьПоОрганизации
	|		ПО питМеню.Номенклатура = ВТ_СтоимостьПоОрганизации.Номенклатура
	|			И (ВТ_Наценка.Организация = ВТ_СтоимостьПоОрганизации.Организация)
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_ЗакупкиТекМесяцСклад КАК ВТ_ЗакупкиТекМесяцСклад
	|		ПО питМеню.Номенклатура = ВТ_ЗакупкиТекМесяцСклад.Номенклатура
	|			И (ВТ_Наценка.СкладРеализации = ВТ_ЗакупкиТекМесяцСклад.СкладРеализации)
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_ЗакупкиТекМесяцПодразделение КАК ВТ_ЗакупкиТекМесяцПодразделение
	|		ПО питМеню.Номенклатура = ВТ_ЗакупкиТекМесяцПодразделение.Номенклатура
	|			И (ВТ_Наценка.Подразделение = ВТ_ЗакупкиТекМесяцПодразделение.Подразделение)
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_ЗакупкиТекМесяцОрганизация КАК ВТ_ЗакупкиТекМесяцОрганизация
	|		ПО питМеню.Номенклатура = ВТ_ЗакупкиТекМесяцОрганизация.Номенклатура
	|			И (ВТ_Наценка.Организация = ВТ_ЗакупкиТекМесяцОрганизация.Организация)
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_ЗакупкиПредМесяцСклад КАК ВТ_ЗакупкиПредМесяцСклад
	|		ПО питМеню.Номенклатура = ВТ_ЗакупкиПредМесяцСклад.Номенклатура
	|			И (ВТ_Наценка.СкладРеализации = ВТ_ЗакупкиПредМесяцСклад.СкладРеализации)
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_ЗакупкиПредМесяцПодразделение КАК ВТ_ЗакупкиПредМесяцПодразделение
	|		ПО питМеню.Номенклатура = ВТ_ЗакупкиПредМесяцПодразделение.Номенклатура
	|			И (ВТ_Наценка.Подразделение = ВТ_ЗакупкиПредМесяцПодразделение.Подразделение)
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_ЗакупкиПредМесяцОрганизация КАК ВТ_ЗакупкиПредМесяцОрганизация
	|		ПО питМеню.Номенклатура = ВТ_ЗакупкиПредМесяцОрганизация.Номенклатура
	|			И (ВТ_Наценка.Организация = ВТ_ЗакупкиПредМесяцОрганизация.Организация)
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_СтоимостьТолькоНоменклатура КАК ВТ_СтоимостьТолькоНоменклатура
	|		ПО питМеню.Номенклатура = ВТ_СтоимостьТолькоНоменклатура.Номенклатура
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_ЗакупкиТекМесяцТолькоНоменклатура КАК ВТ_ЗакупкиТекМесяцТолькоНоменклатура
	|		ПО питМеню.Номенклатура = ВТ_ЗакупкиТекМесяцТолькоНоменклатура.Номенклатура
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_ЗакупкиПредМесяцТолькоНоменклатура КАК ВТ_ЗакупкиПредМесяцТолькоНоменклатура
	|		ПО питМеню.Номенклатура = ВТ_ЗакупкиПредМесяцТолькоНоменклатура.Номенклатура
	|ГДЕ
	|	питМеню.Номенклатура В(&МассивНоменклатуры)
	|	И НЕ питМеню.ЭтоГруппа
	|	И питМеню.Номенклатура <> ЗНАЧЕНИЕ(Справочник.Номенклатура.ПустаяСсылка)
	|	И питМеню.Владелец = ВТ_Наценка.ВидМеню
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	УстановленныеЦены.Номенклатура КАК Номенклатура,
	|	УстановленныеЦены.Цена КАК Цена
	|ПОМЕСТИТЬ ВТ_УстановленныеЦены
	|ИЗ
	|	&УстановленныеЦены КАК УстановленныеЦены
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ_РасчетНаценки.Номенклатура КАК Номенклатура,
	|	ВТ_РасчетНаценки.MRS_СтавкаНДС КАК MRS_СтавкаНДС,
	|	ВТ_РасчетНаценки.ПроцентНаценки КАК ПроцентНаценки,
	|	ВТ_РасчетНаценки.Организация КАК Организация,
	|	ВТ_РасчетНаценки.СкладРеализации КАК СкладРеализации,
	|	ВТ_РасчетНаценки.Стоимость КАК Стоимость,
	|	ВТ_РасчетНаценки.СтоимостьСНаценкой КАК РасчетнаяЦена,
	|	УстановленныеЦены.Цена КАК УстановленнаяЦена
	|ИЗ
	|	ВТ_РасчетНаценки КАК ВТ_РасчетНаценки
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ_УстановленныеЦены КАК УстановленныеЦены
	|		ПО ВТ_РасчетНаценки.Номенклатура = УстановленныеЦены.Номенклатура";
	
	МассивНоменклатуры = ДанныеФормы.Товары.Выгрузить(,"Номенклатура").ВыгрузитьКолонку("Номенклатура");
	УстановленныеЦены = ДанныеФормы.Товары.Выгрузить(,"Номенклатура, Цена");
	ВидЦеныФормы = ДанныеФормы.ВидыЦен.Выгрузить(,"ВидЦены").ВыгрузитьКолонку("ВидЦены");
	
	Запрос.УстановитьПараметр("МассивНоменклатуры", МассивНоменклатуры); 
	Запрос.УстановитьПараметр("УстановленныеЦены", УстановленныеЦены);
	Запрос.УстановитьПараметр("ВидЦены", ВидЦеныФормы[0]);
	Запрос.УстановитьПараметр("ТекущаяДата", ТекущаяДатаСеанса());
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	// Формируем список позиций с отклонениями
	Пока Выборка.Следующий() Цикл                                                                                                    
		
		РасчетнаяЦена = Выборка.РасчетнаяЦена;
		УстановленнаяЦена = Выборка.УстановленнаяЦена;
		
		// Если расчетная цена не определена (нет стоимости) - пропускаем
		Если НЕ ЗначениеЗаполнено(РасчетнаяЦена) Тогда
			Продолжить;
		КонецЕсли;
		
		// Если установленная цена меньше расчетной - добавляем в список
		Если УстановленнаяЦена < Окр(РасчетнаяЦена, 2) Тогда
			
			Отклонение = УстановленнаяЦена - Окр(РасчетнаяЦена, 2);
			ОтклонениеПроцент = ?(РасчетнаяЦена <> 0, (Отклонение / РасчетнаяЦена) * 100, 0);
			
			ПозицияСОтклонением = Новый Структура;
			ПозицияСОтклонением.Вставить("Номенклатура", Выборка.Номенклатура);
			ПозицияСОтклонением.Вставить("УстановленнаяЦена", УстановленнаяЦена);
			ПозицияСОтклонением.Вставить("РасчетнаяЦена", РасчетнаяЦена);
			ПозицияСОтклонением.Вставить("Отклонение", Отклонение);
			ПозицияСОтклонением.Вставить("ОтклонениеПроцент", ОтклонениеПроцент);
			
			Результат.СписокПозиций.Добавить(ПозицияСОтклонением);
			
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

#КонецОбласти

