// Получает Uid физического лица из РС.ДополнительныеСведения
//
// Параметры:
//  ФизЛицоСсылка - СправочникСсылка.ФизическиеЛица - физическое лицо
//
// Возвращаемое значение:
//  Строка - Uid физлица в ЕЛМА или Неопределено если не найден
//
Функция ПолучитьUidФизЛицаЕЛМА(ФизЛицоСсылка) Экспорт
	
	Если НЕ ЗначениеЗаполнено(ФизЛицоСсылка) Тогда
		
		ЗаписатьЛог("Передана пустая ссылка на физическое лицо", УровеньЖурналаРегистрации.Предупреждение);
		Возврат Неопределено;
		
	КонецЕсли;
	
	// Находим свойство с идентификатором MRS_ГУИДЕЛМА
	СвойствоГУИД = ПланыВидовХарактеристик.ДополнительныеРеквизитыИСведения.НайтиПоРеквизиту("ИдентификаторДляФормул", "MRS_ГУИДЗУПЕЛМА");
	
	Если СвойствоГУИД = ПланыВидовХарактеристик.ДополнительныеРеквизитыИСведения.ПустаяСсылка() Тогда
		
		ЗаписатьЛог("Не найдено свойство с ИдентификаторДляФормул = 'MRS_ГУИДЗУПЕЛМА'", УровеньЖурналаРегистрации.Предупреждение);
		Возврат Неопределено;
		
	КонецЕсли;
	
	// Ищем UID ЕЛМА физлица в дополнительных сведениях
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	ДополнительныеСведения.Значение КАК UidЕЛМА
		|ИЗ
		|	РегистрСведений.ДополнительныеСведения КАК ДополнительныеСведения
		|ГДЕ
		|	ДополнительныеСведения.Объект = &Объект
		|	И ДополнительныеСведения.Свойство = &Свойство";
	
	Запрос.УстановитьПараметр("Объект", ФизЛицоСсылка);
	Запрос.УстановитьПараметр("Свойство", СвойствоГУИД);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Если РезультатЗапроса.Пустой() Тогда
		
		ЗаписатьЛог(СтрШаблон("Не найден UID ЕЛМА для физлица '%1'", ФизЛицоСсылка), УровеньЖурналаРегистрации.Предупреждение);
		Возврат Неопределено;
		
	КонецЕсли;
	
	Выборка = РезультатЗапроса.Выбрать();
	Выборка.Следующий();
	
	Возврат Выборка.UidЕЛМА;
	
КонецФункции

// Получает Uid текущего пользователя через его физическое лицо
//
// Возвращаемое значение:
//  Строка - Uid инициатора в ЕЛМА или Неопределено если не найден
//
Функция ПолучитьUidТекущегоПользователяЕЛМА() Экспорт
	
	// Получаем текущего пользователя информационной базы
	ИмяПользователяИБ = ПользователиИнформационнойБазы.ТекущийПользователь().Имя;
	
	// Ищем пользователя в справочнике Пользователи
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	Пользователи.ФизическоеЛицо КАК ФизическоеЛицо
		|ИЗ
		|	Справочник.Пользователи КАК Пользователи
		|ГДЕ
		|	Пользователи.ИдентификаторПользователяИБ = &ИдентификаторПользователяИБ";
	
	Запрос.УстановитьПараметр("ИдентификаторПользователяИБ", ПользователиИнформационнойБазы.ТекущийПользователь().УникальныйИдентификатор);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Если РезультатЗапроса.Пустой() Тогда
		
		ЗаписатьЛог(СтрШаблон("Не найден пользователь с именем ИБ '%1' в справочнике Пользователи", ИмяПользователяИБ), 
			УровеньЖурналаРегистрации.Предупреждение);
		Возврат Неопределено;
		
	КонецЕсли;
	
	Выборка = РезультатЗапроса.Выбрать();
	Выборка.Следующий();
	
	ФизЛицо = Выборка.ФизическоеЛицо;
	
	Если НЕ ЗначениеЗаполнено(ФизЛицо) Тогда
		
		ЗаписатьЛог(СтрШаблон("У пользователя '%1' не заполнено физическое лицо", ИмяПользователяИБ), 
			УровеньЖурналаРегистрации.Предупреждение);
		Возврат Неопределено;
		
	КонецЕсли;
	
	// Получаем UID ЕЛМА для физлица
	UidЕЛМА = ПолучитьUidФизЛицаЕЛМА(ФизЛицо);
	
	Если НЕ ЗначениеЗаполнено(UidЕЛМА) Тогда
		
		ЗаписатьЛог(СтрШаблон("Не найден UID ЕЛМА для физлица '%1' текущего пользователя '%2'", ФизЛицо, ИмяПользователяИБ), 
			УровеньЖурналаРегистрации.Предупреждение);
		Возврат Неопределено;
		
	КонецЕсли;
	
	Возврат UidЕЛМА;
	
КонецФункции

// Получает организацию по её УИД в ЕЛМА
//
// Параметры:
//  УИД - Строка - УИД организации в ЕЛМА
//
// Возвращаемое значение:
//  СправочникСсылка.Организации, Неопределено - найденная организация или Неопределено
//
Функция ПолучитьОрганизациюПоУИД(УИД) Экспорт
	
	Если НЕ ЗначениеЗаполнено(УИД) Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	// Находим свойство с идентификатором MRS_ГУИДЕЛМА
	СвойствоГУИД = ПланыВидовХарактеристик.ДополнительныеРеквизитыИСведения.НайтиПоРеквизиту("ИдентификаторДляФормул", "MRS_ГУИДЕЛМА");
	
	Если СвойствоГУИД = ПланыВидовХарактеристик.ДополнительныеРеквизитыИСведения.ПустаяСсылка() Тогда
		
		ЗаписатьЛог("Не найдено свойство с ИдентификаторДляФормул = 'MRS_ГУИДЕЛМА'", УровеньЖурналаРегистрации.Предупреждение);
		Возврат Неопределено;
		
	КонецЕсли;
	
	// Ищем организацию по дополнительному сведению
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	ДополнительныеСведения.Объект КАК Организация
		|ИЗ
		|	РегистрСведений.ДополнительныеСведения КАК ДополнительныеСведения
		|ГДЕ
		|	ДополнительныеСведения.Свойство = &Свойство
		|	И ДополнительныеСведения.Значение = &Значение";
	
	Запрос.УстановитьПараметр("Свойство", СвойствоГУИД);
	Запрос.УстановитьПараметр("Значение", УИД);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Если РезультатЗапроса.Пустой() Тогда
		
		ЗаписатьЛог(СтрШаблон("Не найдена организация с УИД ЕЛМА '%1'", УИД), УровеньЖурналаРегистрации.Предупреждение);
		Возврат Неопределено;
		
	КонецЕсли;
	
	Выборка = РезультатЗапроса.Выбрать();
	Выборка.Следующий();
	
	Возврат Выборка.Организация;
	
КонецФункции

// Получает физическое лицо по его УИД в ЕЛМА
//
// Параметры:
//  УИД - Строка - УИД физлица в ЕЛМА
//
