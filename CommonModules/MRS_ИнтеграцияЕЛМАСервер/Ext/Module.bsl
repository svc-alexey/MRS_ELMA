Функция ЗначениеСкалярнойДопКонстантыЕЛМА(ИмяКонстанты, ЗначениеПоУмолчанию = "")

	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	ПЛ_ДополнительныеКонстанты.Комментарий КАК Значение
		|ИЗ
		|	РегистрСведений.ПЛ_ДополнительныеКонстанты КАК ПЛ_ДополнительныеКонстанты
		|ГДЕ
		|	ПЛ_ДополнительныеКонстанты.Имя = &Имя";

	Запрос.УстановитьПараметр("Имя", ИмяКонстанты);

	РезультатЗапроса = Запрос.Выполнить();
	Если РезультатЗапроса.Пустой() Тогда
		Возврат ЗначениеПоУмолчанию;
	КонецЕсли;

	Выборка = РезультатЗапроса.Выбрать();
	Выборка.Следующий();

	ЗначениеКонстанты = СокрЛП(Строка(Выборка.Значение));
	Если ПустаяСтрока(ЗначениеКонстанты) Тогда
		Возврат ЗначениеПоУмолчанию;
	КонецЕсли;

	Возврат ЗначениеКонстанты;

КонецФункции

Функция СтрокаСостоитИзЦифрЕЛМА(Значение)

	СтрокаЗначения = СокрЛП(Строка(Значение));
	Если ПустаяСтрока(СтрокаЗначения) Тогда
		Возврат Ложь;
	КонецЕсли;

	Для Индекс = 1 По СтрДлина(СтрокаЗначения) Цикл

		СимволСтроки = Сред(СтрокаЗначения, Индекс, 1);
		Если СтрНайти("0123456789", СимволСтроки) = 0 Тогда
			Возврат Ложь;
		КонецЕсли;

	КонецЦикла;

	Возврат Истина;

КонецФункции

Функция УИДСсылкиДляЕЛМА(Ссылка)

	Если НЕ ЗначениеЗаполнено(Ссылка) Тогда
		Возврат "";
	КонецЕсли;

	Возврат Строка(Ссылка.УникальныйИдентификатор());

КонецФункции

Функция ОбрезатьСтрокуЕЛМА(Значение, МаксимальнаяДлина)

	СтрокаЗначения = Строка(Значение);
	Если СтрДлина(СтрокаЗначения) <= МаксимальнаяДлина Тогда
		Возврат СтрокаЗначения;
	КонецЕсли;

	Возврат Лев(СтрокаЗначения, МаксимальнаяДлина);

КонецФункции

// Разбирает URL на компоненты (схема, хост, порт, путь)
//
// Параметры:
//  URL - Строка - URL для разбора (например, "https://example.com:8080/path")
//
// Возвращаемое значение:
//  Структура:
//   * Схема - Строка - "http" или "https"
//   * Имя - Строка - имя хоста
//   * Порт - Число - порт (80 для http, 443 для https по умолчанию)
//   * Путь - Строка - путь к ресурсу
//
Функция РазобратьURL(URL)
	
	Результат = Новый Структура;
	Результат.Вставить("Схема", "http");
	Результат.Вставить("Имя", "");
	Результат.Вставить("Порт", 0);
	Результат.Вставить("Путь", "");
	
	РабочаяСтрока = СокрЛП(URL);
	
	// Извлечение схемы
	Позиция = СтрНайти(РабочаяСтрока, "://");
	Если Позиция > 0 Тогда
		
		Результат.Схема = НРег(Лев(РабочаяСтрока, Позиция - 1));
		РабочаяСтрока = Сред(РабочаяСтрока, Позиция + 3);
		
	КонецЕсли;
	
	// Извлечение пути (если есть)
	Позиция = СтрНайти(РабочаяСтрока, "/");
	Если Позиция > 0 Тогда
		
		Результат.Путь = Сред(РабочаяСтрока, Позиция);
		РабочаяСтрока = Лев(РабочаяСтрока, Позиция - 1);
		
	КонецЕсли;
	
	// Извлечение порта (если указан)
	Позиция = СтрНайти(РабочаяСтрока, ":");
	Если Позиция > 0 Тогда
		
		СтрокаПорта = СокрЛП(Сред(РабочаяСтрока, Позиция + 1));
		
		// Проверяем, что строка содержит только цифры
		ПортВалиден = Истина;
		Для Индекс = 1 По СтрДлина(СтрокаПорта) Цикл
			
			Символ = Сред(СтрокаПорта, Индекс, 1);
			Если СтрНайти("0123456789", Символ) = 0 Тогда
				ПортВалиден = Ложь;
				Прервать;
			КонецЕсли;
			
		КонецЦикла;
		
		Если ПортВалиден И СтрДлина(СтрокаПорта) > 0 Тогда
			Результат.Порт = Число(СтрокаПорта);
		КонецЕсли;
		
		РабочаяСтрока = Лев(РабочаяСтрока, Позиция - 1);
		
	КонецЕсли;
	
	// Оставшаяся часть - имя хоста
	Результат.Имя = РабочаяСтрока;
	
	// Установка порта по умолчанию, если не указан
	Если Результат.Порт = 0 Тогда
		
		Если Результат.Схема = "https" Тогда
			Результат.Порт = 443;
		Иначе
			Результат.Порт = 80;
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Записывает сообщение в журнал регистрации
//
// Параметры:
//  Сообщение - Строка - текст сообщения
//  Уровень - УровеньЖурналаРегистрации - уровень важности
//
Процедура ЗаписатьЛог(Сообщение, Уровень = Неопределено) Экспорт
	
	Если Уровень = Неопределено Тогда
		Уровень = УровеньЖурналаРегистрации.Информация;
	КонецЕсли;
	
	ЗаписьЖурналаРегистрации("MRS.ЕЛМА", Уровень,,, Сообщение);
	
КонецПроцедуры

Функция ПолучитьДанныеПоВидуЦен(ВидЦены) Экспорт
	
	СтруктураВозврата = Новый Структура;
	
	Запрос = Новый Запрос;

	Запрос.Текст =
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|    питУдаленныеКассы.Организация КАК Организация,
	|    питУдаленныеКассы.Наименование КАК ТочкаПродаж,
	|    питУдаленныеКассы.СкладРеализации КАК СкладРеализации,
	|    ДополнительныеСведения.Значение КАК ГуидЕлмаОрганизации
	|ИЗ
	|    ПланОбмена.питУдаленныеКассы КАК питУдаленныеКассы
	|        ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ДополнительныеСведения КАК ДополнительныеСведения
	|        ПО питУдаленныеКассы.Организация = ДополнительныеСведения.Объект
	|           И ДополнительныеСведения.Свойство.ИдентификаторДляФормул = ""MRS_ГУИДЕЛМА""
	|ГДЕ
	|    питУдаленныеКассы.ВидЦен = &ВидЦен
	|";

	Запрос.УстановитьПараметр("ВидЦен", ВидЦены);
	РезультатЗапроса = Запрос.Выполнить();

	Выборка = РезультатЗапроса.Выбрать();
	Пока Выборка.Следующий() Цикл
		СтруктураВозврата.Вставить("Организация", Выборка.Организация);
		СтруктураВозврата.Вставить("ТочкаПродаж", Выборка.ТочкаПродаж);
		СтруктураВозврата.Вставить("ГуидЕлмаОрганизации", Выборка.ГуидЕлмаОрганизации);
		СтруктураВозврата.Вставить("Склад", Выборка.СкладРеализации);
	КонецЦикла;
	
	Возврат СтруктураВозврата;
	
КонецФункции

// Записывает сведения о запросе и ответе обмена с ELMA в регистр сведений.
//
// Параметры:
//  СтруктураДанныхЗапроса - Структура - Структура с данными для записи в лог.
//
//      Ожидается наличие следующих свойств:
//      * Ссылка       - Ссылка - Ссылка на объект-основание;
//      * IDРесурса    - Строка - Идентификатор ресурса;
//      * ТипЗапроса   - Строка - Тип запроса;
//      * ИмяМетода    - Строка - Имя метода обмена;
//      * ДатаОтправки - Дата   - Дата отправки запроса;
//      * Запрос       - Строка - Текст запроса;
//      * Ответ        - Строка - Текст ответа;
//      * UIDELMA      - Строка - Идентификатор объекта в ELMA;
//      * ID_ELMA      - Строка - Идентификатор записи ELMA.
//
// Возвращаемое значение:
//  Нет.
//
// Описание:
//  На основании переданной структуры формируется запись регистра сведений
//  "ПЛ_ЛогированиеОбменовELMA".
Функция ЗаписьЛогаЗапросов(СтруктураДанныхЗапроса) Экспорт
	
	ТекДата = ТекущаяДатаСеанса();
		
	НоваяЗапись = РегистрыСведений.ПЛ_ЛогированиеОбменовELMA.СоздатьМенеджерЗаписи(); 

	НоваяЗапись.Ссылка			= СтруктураДанныхЗапроса.Ссылка; 
	НоваяЗапись.IDРесурса		= СтруктураДанныхЗапроса.IDРесурса;
	НоваяЗапись.ТипЗапроса		= СтруктураДанныхЗапроса.ТипЗапроса; 
	НоваяЗапись.ИмяМетода		= СтруктураДанныхЗапроса.ИмяМетода; 
	НоваяЗапись.ДатаОтправки	= СтруктураДанныхЗапроса.ДатаОтправки; 
 
	НоваяЗапись.Запрос			= СтруктураДанныхЗапроса.Запрос; 
	НоваяЗапись.Ответ			= СтруктураДанныхЗапроса.Ответ; 
	НоваяЗапись.UIDELMA			= СтруктураДанныхЗапроса.UIDELMA; 
	НоваяЗапись.ID_ELMA			= СтруктураДанныхЗапроса.ID_ELMA; 

	НоваяЗапись.Записать(); 
		
КонецФункции

// Создает и возвращает структуру данных запроса для обмена с ELMA.
//
// Возвращаемое значение:
//  Структура - Структура данных запроса со следующими свойствами:
//      * Ссылка       - Ссылка - Ссылка на объект-основание;
//      * IDРесурса    - Строка - Идентификатор ресурса;
//      * ТипЗапроса   - Строка - Тип запроса;
//      * ИмяМетода    - Строка - Имя метода обмена;
//      * ДатаОтправки - Дата   - Дата отправки запроса;
//      * Запрос       - Строка - Текст запроса;
//      * Ответ        - Строка - Текст ответа;
//      * UIDELMA      - Строка - Идентификатор объекта в ELMA;
//      * ID_ELMA      - Строка - Идентификатор записи ELMA.
//
// Примечание:
//  Все свойства структуры инициализируются значениями по умолчанию.
Функция СоздатьСтруктуруДанныхЗапроса() Экспорт
	
	СтруктураДанныхЗапроса=Новый Структура;
	СтруктураДанныхЗапроса.Вставить("Ссылка","");
	СтруктураДанныхЗапроса.Вставить("IDРесурса","");
	СтруктураДанныхЗапроса.Вставить("ТипЗапроса","");
	СтруктураДанныхЗапроса.Вставить("ИмяМетода","");
	СтруктураДанныхЗапроса.Вставить("ДатаОтправки",Дата(1,1,1));
	СтруктураДанныхЗапроса.Вставить("Запрос","");
	СтруктураДанныхЗапроса.Вставить("Ответ","");
	СтруктураДанныхЗапроса.Вставить("UIDELMA","") ;
	СтруктураДанныхЗапроса.Вставить("ID_ELMA","");
	Возврат СтруктураДанныхЗапроса;
	
КонецФункции

