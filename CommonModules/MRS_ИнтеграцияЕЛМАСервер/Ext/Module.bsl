	Возврат Результат;
	
КонецФункции

// Отправляет статус обеспеченности заказа поставщику в ЕЛМА.
//
// Параметры:
//  ДокументПриобретения - ДокументСсылка.ПриобретениеТоваровУслуг
//  URL - Строка - полный URL шаблона ЕЛМА 365.
//  Таймаут - Число - таймаут HTTP в секундах.
//
// Возвращаемое значение:
//  Структура:
//   * Успех - Булево
//   * ТекстОшибки - Строка
//   * JSONЗапроса - Строка
//   * JSONОтвета - Строка
//   * КодСостояния - Число
//
Функция ОтправитьСтатусЗаказаПоставщикуВЕЛМА(ДокументПриобретения, URL, Таймаут) Экспорт

	Результат = Новый Структура;
	Результат.Вставить("Успех", Ложь);
	Результат.Вставить("ТекстОшибки", "");
	Результат.Вставить("JSONЗапроса", "");
	Результат.Вставить("JSONОтвета", "");
	Результат.Вставить("КодСостояния", 0);

	Попытка

		JSONТекст = СформироватьJSONСтатусаЗаказаПоставщикуЕЛМА(ДокументПриобретения);
		Результат.JSONЗапроса = JSONТекст;

		СтруктураURL = РазобратьURL(URL);

		ЗащищенноеСоединение = Неопределено;
		Если СтруктураURL.Схема = "https" Тогда
			ЗащищенноеСоединение = Новый ЗащищенноеСоединениеOpenSSL(Неопределено, Неопределено);
		КонецЕсли;

		Соединение = Новый HTTPСоединение(
			СтруктураURL.Имя,
			СтруктураURL.Порт,
			,
			,
			,
			Таймаут,
			ЗащищенноеСоединение);

		АдресРесурса = СтруктураURL.Путь;
		Если ПустаяСтрока(АдресРесурса) Тогда
			АдресРесурса = "/";
		КонецЕсли;

		HTTPЗапрос = Новый HTTPЗапрос(АдресРесурса);
		HTTPЗапрос.Заголовки.Вставить("Accept", "application/json");
		HTTPЗапрос.Заголовки.Вставить("Content-Type", "application/json; charset=utf-8");
		HTTPЗапрос.УстановитьТелоИзСтроки(
			JSONТекст,
			КодировкаТекста.UTF8,
			ИспользованиеByteOrderMark.НеИспользовать);

		HTTPОтвет = Соединение.ВызватьHTTPМетод("POST", HTTPЗапрос);
		Результат.КодСостояния = HTTPОтвет.КодСостояния;
		Результат.JSONОтвета = HTTPОтвет.ПолучитьТелоКакСтроку("utf-8");

		Если Результат.КодСостояния >= МинимальныйКодУспешногоHTTPЕЛМА()
			И Результат.КодСостояния < МаксимальныйКодУспешногоHTTPЕЛМА() Тогда
			Результат.Успех = Истина;
		Иначе
			Результат.ТекстОшибки = СтрШаблон("HTTP %1: %2", Результат.КодСостояния, Результат.JSONОтвета);
		КонецЕсли;

	Исключение

		Результат.ТекстОшибки = ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
		ЗаписатьЛог(СтрШаблон("Ошибка отправки статуса заказа поставщику в ЕЛМА: %1",
			Результат.ТекстОшибки), УровеньЖурналаРегистрации.Ошибка);

	КонецПопытки;

	Возврат Результат;

КонецФункции

// Отправляет документ в ЕЛМА, создавая процесс согласования приказа
//
// Параметры:
//  ДокументСсылка - ДокументСсылка.УстановкаЦенНоменклатуры
//  AuthToken - Строка - токен авторизации ЕЛМА
