	Если РезультатЗапроса.Пустой() Тогда
		
		ЗаписатьЛог(СтрШаблон("Не найдено физическое лицо с УИД ЕЛМА '%1'", УИД), УровеньЖурналаРегистрации.Предупреждение);
		Возврат Неопределено;
		
	КонецЕсли;
	
	Выборка = РезультатЗапроса.Выбрать();
	Выборка.Следующий();
	
	Возврат Выборка.ФизическоеЛицо;
	
КонецФункции

#КонецОбласти

#Область ПроведениеИВыгрузка

// Проводит документы, у которых наступила дата применения
//
// Возвращаемое значение:
//  Структура:
//   * Проведено - Число
//   * Ошибок - Число
//
Функция ПровестиДокументыПоДатеПрименения() Экспорт
	
	Результат = Новый Структура("Проведено, Ошибок", 0, 0);
	
	// Выборка документов для проведения
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ПроцессыЕЛМА.Документ1С КАК Документ1С,
		|	Документ.ДатаНачалаДействия КАК ДатаНачалаДействия
		|ИЗ
		|	РегистрСведений.MRS_ПроцессыЕЛМА КАК ПроцессыЕЛМА
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.УстановкаЦенНоменклатуры КАК Документ
		|		ПО ПроцессыЕЛМА.Документ1С = Документ.Ссылка
		|ГДЕ
		|	ПроцессыЕЛМА.Статус = ЗНАЧЕНИЕ(Перечисление.MRS_СтатусыСинхронизацииELMA.Подписан)
		|	И (ПроцессыЕЛМА.ВидПроцесса = &ВидПроцесса
		|		ИЛИ ПроцессыЕЛМА.ВидПроцесса = """")
		|	И Документ.ДатаНачалаДействия <= &ТекущаяДата
		|	И НЕ Документ.Проведен";
	
	Запрос.УстановитьПараметр("ТекущаяДата", ТекущаяДатаСеанса());
	Запрос.УстановитьПараметр("ВидПроцесса", ВидПроцессаПриказЕЛМА());
	
	РезультатЗапроса = Запрос.Выполнить();
	Выборка = РезультатЗапроса.Выбрать();
	
	Пока Выборка.Следующий() Цикл
		
		Попытка
			
			// Проведение документа
			ДокументОбъект = Выборка.Документ1С.ПолучитьОбъект();
			ДокументОбъект.Записать(РежимЗаписиДокумента.Проведение);
			
			ЗаписатьЛог(СтрШаблон("Документ %1 успешно проведен по дате применения", Выборка.Документ1С), 
				УровеньЖурналаРегистрации.Информация);
			
			Результат.Проведено = Результат.Проведено + 1;
			
			// Выгрузка цен в Simphony
			Попытка
				ВыгрузитьЦеныВSimphony(Выборка.Документ1С);
			Исключение
				ЗаписатьЛог(СтрШаблон("Ошибка выгрузки цен в Simphony для документа %1: %2", 
					Выборка.Документ1С, ПодробноеПредставлениеОшибки(ИнформацияОбОшибке())), 
					УровеньЖурналаРегистрации.Ошибка);
			КонецПопытки;
			
		Исключение
			
			ЗаписатьЛог(СтрШаблон("Ошибка проведения документа %1: %2", 
				Выборка.Документ1С, ПодробноеПредставлениеОшибки(ИнформацияОбОшибке())), 
				УровеньЖурналаРегистрации.Ошибка);
			
			Результат.Ошибок = Результат.Ошибок + 1;
			
		КонецПопытки;
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

// Выгружает цены из документа в Simphony
//
// Параметры:
//  ДокументСсылка - ДокументСсылка.УстановкаЦенНоменклатуры
//
// Возвращаемое значение:
//  Булево - Истина если выгрузка выполнена
//
Процедура ВыгрузитьЦеныВSimphony(ДокументСсылка) Экспорт
		
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	питМеню.Ссылка КАК ПозицияМеню,
	|	питУдаленныеКассы.Ссылка КАК КассовыйУзел
	|ИЗ
	|	Документ.УстановкаЦенНоменклатуры.Товары КАК УстановкаЦен
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.MRS_ПроцессыELMA КАК ПроцессыЕЛМА
	|		ПО (УстановкаЦен.Ссылка = ПроцессыЕЛМА.Документ1С)
	|			И (ПроцессыЕЛМА.Статус = ЗНАЧЕНИЕ(Перечисление.MRS_СтатусыСинхронизацииELMA.Подписан))
	|			И (ПроцессыЕЛМА.ВидПроцесса = &ВидПроцесса
	|				ИЛИ ПроцессыЕЛМА.ВидПроцесса = """")
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ПланОбмена.питУдаленныеКассы КАК питУдаленныеКассы
	|		ПО (УстановкаЦен.ВидЦены = питУдаленныеКассы.ВидЦен)
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ПланОбмена.питУдаленныеКассы.ВидыМеню КАК питУдаленныеКассыВидыМеню
	|		ПО (питУдаленныеКассы.Ссылка = питУдаленныеКассыВидыМеню.Ссылка)
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.питМеню КАК питМеню
	|		ПО (питМеню.Владелец = питУдаленныеКассыВидыМеню.ВидМеню)
	|			И (питМеню.Номенклатура = УстановкаЦен.Номенклатура)
	|ГДЕ
	|	УстановкаЦен.Ссылка.Проведен
	|	И УстановкаЦен.Ссылка = &Документ
	|	И НЕ питМеню.ЭтоГруппа";
	
	Запрос.УстановитьПараметр("Документ", ДокументСсылка.Ссылка);
	Запрос.УстановитьПараметр("ВидПроцесса", ВидПроцессаПриказЕЛМА());
	
	Результат = Запрос.Выполнить();
	
	Если Результат.Пустой() Тогда
		ЗаписатьЛог(СтрШаблон("Цены из документа %1 НЕ поставлены в очередь выгрузки Simphony", ДокументСсылка), 
		УровеньЖурналаРегистрации.Информация);
	КонецЕсли;
	
	Выборка = Результат.Выбрать();
	
	Пока Выборка.Следующий() Цикл
		
		// Постановка позиции в очередь выгрузки Simphony
		MRS_ИнтеграцияSimphonyСервер.ДобавитьВОчередьВыгрузки(
			Выборка.ПозицияМеню,
			"UPDATE",
			Выборка.КассовыйУзел);
				
	КонецЦикла;
	
	ЗаписатьЛог(СтрШаблон("Цены из документа %1 поставлены в очередь выгрузки Simphony", ДокументСсылка), 
		УровеньЖурналаРегистрации.Информация);
		
КонецПроцедуры

#КонецОбласти

#Область ФормированиеПриказа

// Формирует Word-документ приказа для отправки в ЕЛМА
//
// Параметры:
//  СсылкаДокумента - ДокументСсылка.УстановкаЦенНоменклатуры - документ для формирования приказа
//
// Возвращаемое значение:
//  ДвоичныеДанные - содержимое Word-файла приказа, Неопределено при ошибке
//
Функция СформироватьПриказЕЛМА(СсылкаДокумента, ПараметрыПриказа = Неопределено) Экспорт
	
	Попытка
		
		ОбъектДок = СсылкаДокумента.ПолучитьОбъект();
		
		Если ПараметрыПриказа = Неопределено Тогда
			ПараметрыПриказа = ПолучитьСохраненныеПараметрыПриказа(СсылкаДокумента);
		КонецЕсли;	
		
		// Конвертируем ТаблицуЗначений в Массив для избежания ошибки сериализации при передаче на клиент
	    Если ПараметрыПриказа <> Неопределено 
	      И ПараметрыПриказа.Свойство("СписокКОзнакомлению") 
	      И ТипЗнч(ПараметрыПриказа.СписокКОзнакомлению) = Тип("ТаблицаЗначений") Тогда
	      
		      МассивСтрок = Новый Массив;
		      Для Каждого СтрокаТЗ Из ПараметрыПриказа.СписокКОзнакомлению Цикл
		        СтруктураСтроки = Новый Структура("ФизическоеЛицо", СтрокаТЗ.ФизическоеЛицо);
		        МассивСтрок.Добавить(СтруктураСтроки);
		      КонецЦикла;
		      
		      ПараметрыПриказа.СписокКОзнакомлению = МассивСтрок;
	      
	  КонецЕсли;
  
		// Организация берется из параметров приказа (ПараметрыПриказа.Организация)
		Организация = "";
		Если ПараметрыПриказа <> Неопределено И ПараметрыПриказа.Свойство("Организация") Тогда
			Организация = ПараметрыПриказа.Организация;
		КонецЕсли;
		
		ДанныеОбъекта = ПолучитьДанныеДляПриказа(ОбъектДок, Организация, ПараметрыПриказа);
		
		МакетДвоичныеДанные = ПолучитьМакетПриказаЕЛМА();
		Если МакетДвоичныеДанные = Неопределено Тогда
			ВызватьИсключение "Макет печати ""ПриказЕЛМА"" не найден.";
		КонецЕсли;
		
		ТипМакета = "DOCX";
		Макет = УправлениеПечатью.ИнициализироватьМакетОфисногоДокумента(МакетДвоичныеДанные, ТипМакета);
		ПечатнаяФорма = УправлениеПечатью.ИнициализироватьПечатнуюФорму(ТипМакета, , Макет);
		
		Если ПечатнаяФорма = Неопределено Или Макет = Неопределено Тогда
			ВызватьИсключение "Не удалось инициализировать печатную форму или макет";
		КонецЕсли;
		
		ОписаниеОбластей = ПолучитьОписаниеОбластейМакетаПриказа();
		
		Если ОписаниеОбластей.Свойство("ВерхнийКолонтитул") Тогда
			Попытка
				Область = УправлениеПечатью.ОбластьМакета(Макет, ОписаниеОбластей["ВерхнийКолонтитул"]); 
				Если Область <> Неопределено Тогда
					УправлениеПечатью.ПрисоединитьОбластьИЗаполнитьПараметры(ПечатнаяФорма, Область, ДанныеОбъекта, Ложь);
					ЗаписатьЛог("Область ВерхнийКолонтитул заполнена успешно", УровеньЖурналаРегистрации.Информация);
				Иначе
					ЗаписатьЛог("Область ВерхнийКолонтитул не найдена в макете", УровеньЖурналаРегистрации.Предупреждение);
				КонецЕсли;
			Исключение
				ЗаписатьЛог("Ошибка при обработке области ВерхнийКолонтитул: " + КраткоеПредставлениеОшибки(ИнформацияОбОшибке()), 
					УровеньЖурналаРегистрации.Предупреждение);
			КонецПопытки;
		КонецЕсли;
		
		Если ОписаниеОбластей.Свойство("Шапка") Тогда
			Попытка
				Область = УправлениеПечатью.ОбластьМакета(Макет, ОписаниеОбластей["Шапка"]);
				Если Область <> Неопределено Тогда
					УправлениеПечатью.ПрисоединитьОбластьИЗаполнитьПараметры(ПечатнаяФорма, Область, ДанныеОбъекта, Ложь);
					ЗаписатьЛог("Область Шапка заполнена успешно", УровеньЖурналаРегистрации.Информация);
				Иначе
					ЗаписатьЛог("Область Шапка не найдена в макете", УровеньЖурналаРегистрации.Предупреждение);
				КонецЕсли;
			Исключение
				ЗаписатьЛог("Ошибка при обработке области Шапка: " + КраткоеПредставлениеОшибки(ИнформацияОбОшибке()), 
					УровеньЖурналаРегистрации.Предупреждение);
			КонецПопытки;
		КонецЕсли;
		
		Если ОписаниеОбластей.Свойство("СтрокаТаблицы") Тогда
			Попытка
				ОбластьСтроки = УправлениеПечатью.ОбластьМакета(Макет, ОписаниеОбластей["СтрокаТаблицы"]);
				
				Если ОбластьСтроки <> Неопределено Тогда
					
					Для Каждого СтрокаТовары Из ОбъектДок.Товары Цикл
						
						ДанныеСтроки = Новый Структура;
						
						ПозицияМеню = ПолучитьПозициюМенюПоНоменклатуре(СтрокаТовары.Номенклатура);
						Если ПозицияМеню <> Неопределено Тогда
							ДанныеСтроки.Вставить("ТоварыНоменклатура", Строка(ПозицияМеню));
						Иначе
							ДанныеСтроки.Вставить("ТоварыНоменклатура", Строка(СтрокаТовары.Номенклатура));
						КонецЕсли;
						
						ДанныеСтроки.Вставить("ТипИзменения", "Установка цен");
						ДанныеСтроки.Вставить("НоваяЦена", Формат(СтрокаТовары.Цена, "ЧЦ=15; ЧДЦ=2; ЧН=0,00"));
						ДанныеСтроки.Вставить("НовоеНазвание", Строка(СтрокаТовары.Номенклатура));
						ДанныеСтроки.Вставить("Склад", ДанныеОбъекта.Склад);
						ДанныеСтроки.Вставить("НДС", "Без НДС");
						
						УправлениеПечатью.ПрисоединитьОбластьИЗаполнитьПараметры(ПечатнаяФорма, ОбластьСтроки, ДанныеСтроки, Ложь);
						
					КонецЦикла;
					
					ЗаписатьЛог(СтрШаблон("Область СтрокаТаблицы заполнена, обработано строк: %1", ОбъектДок.Товары.Количество()), 
						УровеньЖурналаРегистрации.Информация);
				Иначе
					ЗаписатьЛог("Область СтрокаТаблицы не найдена в макете", УровеньЖурналаРегистрации.Предупреждение);
				КонецЕсли;
				
			Исключение
				ЗаписатьЛог("Ошибка при обработке области СтрокаТаблицы: " + КраткоеПредставлениеОшибки(ИнформацияОбОшибке()), 
					УровеньЖурналаРегистрации.Предупреждение);
			КонецПопытки;
		КонецЕсли;
		
		Если ОписаниеОбластей.Свойство("Подвал") Тогда
			Попытка
				Область = УправлениеПечатью.ОбластьМакета(Макет, ОписаниеОбластей["Подвал"]);
				Если Область <> Неопределено Тогда
					УправлениеПечатью.ПрисоединитьОбластьИЗаполнитьПараметры(ПечатнаяФорма, Область, ДанныеОбъекта, Ложь);
					ЗаписатьЛог("Область Подвал заполнена успешно", УровеньЖурналаРегистрации.Информация);
				Иначе
					ЗаписатьЛог("Область Подвал не найдена в макете", УровеньЖурналаРегистрации.Предупреждение);
				КонецЕсли;
			Исключение
				ЗаписатьЛог("Ошибка при обработке области Подвал: " + КраткоеПредставлениеОшибки(ИнформацияОбОшибке()), 
					УровеньЖурналаРегистрации.Предупреждение);
			КонецПопытки;
		КонецЕсли;
		
		// Заполняем параметры во всём документе (включая колонтитулы)
		Попытка
			УправлениеПечатью.ЗаполнитьПараметры(ПечатнаяФорма.СтруктураДокумента, ДанныеОбъекта);
		Исключение
			ЗаписатьЛог("Предупреждение при заполнении параметров: " + КраткоеПредставлениеОшибки(ИнформацияОбОшибке()), 
				УровеньЖурналаРегистрации.Предупреждение);
		КонецПопытки;
		
		АдресВоВременномХранилище = УправлениеПечатью.СформироватьДокумент(ПечатнаяФорма);
		ДвоичныеДанные = ПолучитьИзВременногоХранилища(АдресВоВременномХранилище);
		
		Возврат ДвоичныеДанные;
		
	Исключение
		
		ЗаписатьЛог("Ошибка формирования приказа ЕЛМА: " + ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()), 
			УровеньЖурналаРегистрации.Ошибка);
		
		Возврат Неопределено;
		
	КонецПопытки;
	
КонецФункции

Функция ПолучитьМакетПриказаЕЛМА()
	
	МакетДвоичныеДанные = Неопределено;
	
	МакетДвоичныеДанные = ПолучитьПользовательскийМакетПечати("Документ.УстановкаЦенНоменклатуры", "ПриказЕЛМА");
	
	Возврат МакетДвоичныеДанные;
	
КонецФункции

Функция ПолучитьДанныеДляПриказа(ОбъектДок, Организация, ПараметрыПриказа)
	
	ДанныеОбъекта = Новый Структура;
	
	ДанныеОбъекта.Вставить("Организация", Организация);
	ДанныеОбъекта.Вставить("СсылкаДата", Формат(ОбъектДок.Дата, "ДЛФ=D"));
	ДанныеОбъекта.Вставить("НомерПриказа", ОбъектДок.Номер);
	ДанныеОбъекта.Вставить("Тема", ПараметрыПриказа.Тема);
	ДанныеОбъекта.Вставить("Цель", ПараметрыПриказа.Цель);
	ДанныеОбъекта.Вставить("Склад", ПараметрыПриказа.Склад);

	Если ПараметрыПриказа <> Неопределено И ПараметрыПриказа.Свойство("ДатаНачалаДействия") Тогда
		ДанныеОбъекта.Вставить("ДатаНачалаДействия", Формат(ПараметрыПриказа.ДатаНачалаДействия, "ДЛФ=D"));
	Иначе
		ДанныеОбъекта.Вставить("ДатаНачалаДействия", "");
	КонецЕсли;
	
	Возврат ДанныеОбъекта;
	
КонецФункции

Функция ПолучитьОписаниеОбластейМакетаПриказа()
	
	ОписаниеОбластей = Новый Структура;
	
	УправлениеПечатью.ДобавитьОписаниеОбласти(ОписаниеОбластей, "Шапка", "Общая");
	УправлениеПечатью.ДобавитьОписаниеОбласти(ОписаниеОбластей, "СтрокаТаблицы", "СтрокаТаблицы");
	//УправлениеПечатью.ДобавитьОписаниеОбласти(ОписаниеОбластей, "Подвал", "Общая");
	
	Возврат ОписаниеОбластей;
	
КонецФункции 

// Получает пользовательский макет печати из РС.ПользовательскиеМакетыПечати (если РС доступен)
//
// Параметры:
//  Объект - Строка - имя объекта (например, "Документ.УстановкаЦенНоменклатуры")
//  ИмяМакета - Строка - имя макета (например, "ПриказЕЛМА")
//
// Возвращаемое значение:
//  ДвоичныеДанные, Неопределено - двоичные данные макета или Неопределено если не найден
//
Функция ПолучитьПользовательскийМакетПечати(Объект, ИмяМакета)
	
	МакетПФ = ПЛ_ДополнительныеКонстантыПовтИсп.ВернутьДополнительнуюКонстанту("ШаблонПриказаЕЛМА");
	
	Если МакетПФ = Неопределено Тогда
		
		ЗаписатьЛог(СтрШаблон("Ошибка получения пользовательского макета %1: %2", 
			ИмяМакета, ОписаниеОшибки()), УровеньЖурналаРегистрации.Ошибка);
			
		Возврат Неопределено;
	Иначе 
		СтруктураФайла = РаботаСФайламиСлужебныйВызовСервера.ДанныеФайлаИДвоичныеДанные(МакетПФ);

		Возврат СтруктураФайла.ДвоичныеДанные;
	КонецЕсли;
		
КонецФункции

// Получает позицию меню по номенклатуре
//
// Параметры:
//  Номенклатура - СправочникСсылка.Номенклатура
//
// Возвращаемое значение:
//  СправочникСсылка.питМеню, Неопределено
//
Функция ПолучитьПозициюМенюПоНоменклатуре(Номенклатура)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	питМеню.Ссылка КАК Ссылка
		|ИЗ
		|	Справочник.питМеню КАК питМеню
		|ГДЕ
		|	питМеню.Номенклатура = &Номенклатура
		|	И НЕ питМеню.ЭтоГруппа";
	
	Запрос.УстановитьПараметр("Номенклатура", Номенклатура);
	
	Результат = Запрос.Выполнить();
	
	Если Результат.Пустой() Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Выборка = Результат.Выбрать();
	Выборка.Следующий();
	
	Возврат Выборка.Ссылка;
	
КонецФункции

#КонецОбласти

#Область ОбменЕлмаPOSСистемы

// Обрабатывает XML-ответ с кодами номенклатуры, выполняет поиск номенклатуры
// по переданным кодам и формирует XML-ответ с результатами поиска.
//
// Параметры:
//  ТекстВходящегоЗапроса - Строка - XML-строка входящего запроса.
//      Ожидается, что XML содержит элементы <string>, в которых переданы коды
//      номенклатуры для поиска.
//
// Возвращаемое значение:
//  Строка - XML-строка ответа следующей структуры:
//      <Response>
//          <items>
//              <item>
//                  <code>КодНоменклатуры</code>
//                  <name>НаименованиеНоменклатурыИлиТекстОшибки</name>
//                  <unitname>ПолноеНаименованиеЕдиницыИзмерения</unitname>
//              </item>
//          </items>
//      </Response>
//
//      Если номенклатура по коду не найдена, в элементе <name> возвращается
//      текст: "Не найдена номенклатура по коду: <код>".
//      Элемент <unitname> в этом случае не заполняется.
//
// Особенности:
//  - Поиск выполняется по первым 20 символам кода.             
Функция ОбработатьОтветПоискНоменклатуры(ТекстВходящегоЗапроса) Экспорт
    
    // Создаем таблицу значений для результата
    ТаблицаКодов = Новый ТаблицаЗначений;
    ТаблицаКодов.Колонки.Добавить("Код", Новый ОписаниеТипов("Строка"));
    ТаблицаКодов.Колонки.Добавить("Найден", Новый ОписаниеТипов("Булево"));
	ТаблицаКодов.Колонки.Добавить("Наименование", Новый ОписаниеТипов("Строка"));
	ТаблицаКодов.Колонки.Добавить("ЕдиницаИзмеренияНаименование", Новый ОписаниеТипов("Строка"));
    
    // Читаем XML
    ЧтениеXML = Новый ЧтениеXML;
    ЧтениеXML.УстановитьСтроку(ТекстВходящегоЗапроса);
    
    // Парсим XML через построитель DOM
    ПостроительDOM = Новый ПостроительDOM;
    ДокументDOM = ПостроительDOM.Прочитать(ЧтениеXML);
    
    // Получаем все элементы string
    СписокЭлементов = ДокументDOM.ПолучитьЭлементыПоИмени("string");
    
    // Заполняем таблицу значений
    Для Каждого Элемент Из СписокЭлементов Цикл
        Код = СокрЛП(Элемент.ТекстовоеСодержимое);
        НоваяСтрока = ТаблицаКодов.Добавить();
        НоваяСтрока.Код = Код;
        НоваяСтрока.Найден = Ложь;
    КонецЦикла;
    
    // Поиск в справочнике Номенклатура
    Запрос = Новый Запрос;
    Запрос.Текст = 
    "ВЫБРАТЬ
    |	ТаблицаКодов.Код КАК Код
    |ПОМЕСТИТЬ ВТ_Коды
    |ИЗ
    |	&ТаблицаКодов КАК ТаблицаКодов
    |;
    |
    |////////////////////////////////////////////////////////////////////////////////
    |ВЫБРАТЬ
    |	ВТ_Коды.Код КАК Код,
    |	Номенклатура.Ссылка ЕСТЬ НЕ NULL  КАК Найден,
    |	Номенклатура.Наименование КАК Наименование,
    |	Номенклатура.ЕдиницаИзмерения.НаименованиеПолное КАК ЕдиницаИзмеренияНаименование
    |ИЗ
    |	ВТ_Коды КАК ВТ_Коды
    |		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК Номенклатура
    |		ПО (ПОДСТРОКА(ВТ_Коды.Код, 1, 20) = ПОДСТРОКА(Номенклатура.Код, 1, 20))";
    
    Запрос.УстановитьПараметр("ТаблицаКодов", ТаблицаКодов);
    РезультатЗапроса = Запрос.Выполнить();
    
    // Обновляем таблицу с признаком найденных элементов
    Выборка = РезультатЗапроса.Выбрать();
    Пока Выборка.Следующий() Цикл
        НайденныеСтроки = ТаблицаКодов.НайтиСтроки(Новый Структура("Код", Выборка.Код));
        Для Каждого Строка Из НайденныеСтроки Цикл
            Строка.Найден = Выборка.Найден;
			Строка.Наименование = Выборка.Наименование;
			Строка.ЕдиницаИзмеренияНаименование = Выборка.ЕдиницаИзмеренияНаименование;
        КонецЦикла;
    КонецЦикла;
    
    // Формируем XML ответ только с ненайденными кодами
    ЗаписьXML = Новый ЗаписьXML;
    ЗаписьXML.УстановитьСтроку();
	ЗаписьXML.ЗаписатьОбъявлениеXML();
    ЗаписьXML.ЗаписатьНачалоЭлемента("Response");
    ЗаписьXML.ЗаписатьАтрибут("xmlns:xsd", "http://www.w3.org/2001/XMLSchema");
    ЗаписьXML.ЗаписатьАтрибут("xmlns:xsi", "http://www.w3.org/2001/XMLSchema-instance");
	
    ЗаписьXML.ЗаписатьНачалоЭлемента("items");
    
    Для Каждого Строка Из ТаблицаКодов Цикл
		
		 ЗаписьXML.ЗаписатьНачалоЭлемента("item");
		 
            ЗаписьXML.ЗаписатьНачалоЭлемента("code");
            ЗаписьXML.ЗаписатьТекст(Строка.Код);
            ЗаписьXML.ЗаписатьКонецЭлемента(); 
			
						
			Если Строка.Найден Тогда

				ЗаписьXML.ЗаписатьНачалоЭлемента("name");
				ЗаписьXML.ЗаписатьТекст(Строка.Наименование);
				ЗаписьXML.ЗаписатьКонецЭлемента(); //name
				
				ЗаписьXML.ЗаписатьНачалоЭлемента("unitname");
				ЗаписьXML.ЗаписатьТекст(Строка.ЕдиницаИзмеренияНаименование);
				ЗаписьXML.ЗаписатьКонецЭлемента(); //ЕдиницаИзмеренияНаименование

			Иначе
				
				ЗаписьXML.ЗаписатьНачалоЭлемента("name");
				ЗаписьXML.ЗаписатьТекст("Не найдена номенклатура по коду: " + Строка.Код);
				ЗаписьXML.ЗаписатьКонецЭлемента(); //name
				
			КонецЕсли;
			
						
						
		ЗаписьXML.ЗаписатьКонецЭлемента();//items
		
    КонецЦикла;
    
    ЗаписьXML.ЗаписатьКонецЭлемента(); // items
    ЗаписьXML.ЗаписатьКонецЭлемента(); // Request
    
    Возврат ЗаписьXML.Закрыть();

КонецФункции

// Формирует XML-ответ со статусом обработки запроса поиска номенклатуры.
//
// Параметры:
//  СтрокаОшибки - Строка - Текст ошибки.
//      Необязательный параметр. Если ошибка отсутствует, может передаваться
//      пустая строка.
//
// Возвращаемое значение:
//  Строка - XML-строка ответа следующей структуры:
//      <Response>
//          <status xsi:type="xsd:string">2</status>
//          <Err_String>ТекстОшибки</Err_String>
//      </Response>
//
// Примечание:
//  Значение статуса "2" записывается в ответ как признак ошибочного
Функция СформироватьСтатусОтвета_ПоискНоменклатуры(СтрокаОшибки = "") Экспорт
	
	// Формируем XML ответ только с ненайденными кодами
    ЗаписьXML = Новый ЗаписьXML;
    ЗаписьXML.УстановитьСтроку();
    ЗаписьXML.ЗаписатьНачалоЭлемента("Response");
    ЗаписьXML.ЗаписатьАтрибут("xmlns:xsd", "http://www.w3.org/2001/XMLSchema");
    ЗаписьXML.ЗаписатьАтрибут("xmlns:xsi", "http://www.w3.org/2001/XMLSchema-instance");
	ЗаписьXML.ЗаписатьНачалоЭлемента("status");
	ЗаписьXML.ЗаписатьАтрибут("xsi:type", "xsd:string");
	ЗаписьXML.ЗаписатьТекст(Строка(2));
	ЗаписьXML.ЗаписатьКонецЭлемента();
	ЗаписьXML.ЗаписатьНачалоЭлемента("Err_String");
	ЗаписьXML.ЗаписатьТекст(СтрокаОшибки);
	ЗаписьXML.ЗаписатьКонецЭлемента(); //
	  
	Возврат ЗаписьXML.Закрыть();
			
КонецФункции

// Выполняет разбор входящего XML с элементами correspondence и формирует
// структуру результата со списком соответствий, признаками ошибок и текстом
// обнаруженных проблем.
//
// Параметры:
//  ТекстВходящегоЗапроса - Строка - Текст входящего XML.
//
// Возвращаемое значение:
//  Структура - Результат разбора XML со следующими полями:
//      * ЕстьОшибки   - Булево - Признак наличия ошибок при разборе
//        и проверке данных.
//      * ТекстОшибки  - Строка - Описание выявленных ошибок.
//      * Соответствия - Массив - Массив структур с данными соответствий.
//
//      Каждый элемент массива "Соответствия" содержит структуру полей:
//      * FrontSystem - Строка - Наименование фронтовой системы.
//      * ButtonKey   - Строка - Ключ кнопки.
//      * ButtonName  - Строка - Наименование кнопки.
//      * QPU         - Число  - Количество.
//      * ItemCode    - Строка - Код номенклатуры.
//
// Особенности:
//  - Если значение поля QPU не удалось преобразовать в число, в результат
//    записывается 0, а в ТекстОшибки добавляется описание ошибки.
//  - После разбора выполняется проверка обязательных полей.
//  - Если в XML не найдено ни одного элемента correspondence, в результат
//    записывается ошибка.
Функция ОбработкаСтруктурыСоответсвийФронта(ТекстВходящегоЗапроса) Экспорт
	
	// Основная структура результата
	Результат = Новый Структура;
	Результат.Вставить("ЕстьОшибки", Ложь);
	Результат.Вставить("ТекстОшибки", "");
	Результат.Вставить("Соответствия", Новый Массив);
	
	// Создаем читатель XML
	ЧтениеXML = Новый ЧтениеXML;
	ЧтениеXML.УстановитьСтроку(ТекстВходящегоЗапроса);
	
	Попытка
		Пока ЧтениеXML.Прочитать() Цикл
			Если ЧтениеXML.ТипУзла = ТипУзлаXML.НачалоЭлемента И ЧтениеXML.Имя = "correspondence" Тогда
				
				// Структура для одного соответствия с пустыми значениями по умолчанию
				ТекущееСоответствие = Новый Структура;
				ТекущееСоответствие.Вставить("FrontSystem", "");
				ТекущееСоответствие.Вставить("ButtonKey", "");
				ТекущееСоответствие.Вставить("ButtonName", "");
				ТекущееСоответствие.Вставить("QPU", 0);
				ТекущееСоответствие.Вставить("ItemCode", "");
				
				// Читаем содержимое correspondence
				Пока ЧтениеXML.Прочитать() И ЧтениеXML.ТипУзла <> ТипУзлаXML.КонецЭлемента Цикл
					Если ЧтениеXML.ТипУзла = ТипУзлаXML.НачалоЭлемента Тогда
						ИмяПоля = ЧтениеXML.Имя;
						// Читаем значение элемента
						ЗначениеПоля = "";
						Пока ЧтениеXML.Прочитать() И ЧтениеXML.ТипУзла <> ТипУзлаXML.КонецЭлемента Цикл
							Если ЧтениеXML.ТипУзла = ТипУзлаXML.Текст Тогда
								ЗначениеПоля = ЧтениеXML.Значение;
							КонецЕсли;
						КонецЦикла;
						
						// Записываем значение, если поле есть в структуре
						Если ТекущееСоответствие.Свойство(ИмяПоля) Тогда
							Если ИмяПоля = "QPU" Тогда
								Попытка
									ТекущееСоответствие[ИмяПоля] = Число(ЗначениеПоля);
								Исключение
									ТекущееСоответствие[ИмяПоля] = 0;
									Результат.ТекстОшибки = Результат.ТекстОшибки + 
										"Ошибка преобразования QPU в число: " + ОписаниеОшибки() + Символы.ПС;
								КонецПопытки;
							Иначе
								ТекущееСоответствие[ИмяПоля] = ЗначениеПоля;
							КонецЕсли;
						КонецЕсли;
					КонецЕсли;
				КонецЦикла;
				
				// Добавляем соответствие в массив независимо от заполненности
				Результат.Соответствия.Добавить(ТекущееСоответствие);
			КонецЕсли;
		КонецЦикла;
		
		ЧтениеXML.Закрыть();
		
		// Проверка обязательных полей после заполнения всех данных
		ОбязательныеПоля = Новый Массив;
		ОбязательныеПоля.Добавить("FrontSystem");
		ОбязательныеПоля.Добавить("ButtonKey");
		ОбязательныеПоля.Добавить("ButtonName");
		ОбязательныеПоля.Добавить("QPU");
		ОбязательныеПоля.Добавить("ItemCode");
		
		Для Каждого Соответствие Из Результат.Соответствия Цикл
			Для Каждого Поле Из ОбязательныеПоля Цикл
				Если НЕ ЗначениеЗаполнено(Соответствие[Поле]) Тогда
					Результат.ЕстьОшибки = Истина;
					Результат.ТекстОшибки = Результат.ТекстОшибки + 
						"Отсутствует или не заполнено поле " + Поле + " в correspondence" + Символы.ПС;
				КонецЕсли;
			КонецЦикла;
		КонецЦикла;
		
		Если Результат.Соответствия.Количество() = 0 Тогда
			Результат.ЕстьОшибки = Истина;
			Результат.ТекстОшибки = Результат.ТекстОшибки + 
				"Не найдено ни одного элемента correspondence в XML" + Символы.ПС;
		КонецЕсли;
		
	Исключение
		Результат.ЕстьОшибки = Истина;
		Результат.ТекстОшибки = "Ошибка разбора XML: " + ОписаниеОшибки();
		ЧтениеXML.Закрыть();
	КонецПопытки;
	
	Возврат Результат;	
	    
КонецФункции

// Записывает соответствия фронтовой системы в регистр сведений на основании
// переданного массива данных.
//
// Параметры:
//  Массив - Массив - Массив структур соответствий.
//
// Возвращаемое значение:
//  Структура - Структура результата выполнения:
//      ЕстьОшибки - Булево - Признак наличия ошибок при обработке и записи;
//      ТекстОшибки - Строка - Текст ошибок, возникших при обработке.
//
// Описание обработки:
//  Для каждого элемента массива выполняются следующие действия:
//  - определяется номенклатура по коду;
//  - определяется тип фронтовой системы;
//  - выполняется поиск существующей записи в регистре сведений;
//  - при наличии запись обновляется, при отсутствии создается новая.
//
// Примечание:
//  Если номенклатура по коду не найдена, соответствие не записывается,
//  а в результат добавляется сообщение об ошибке.
Функция ЗаписатьСоответствияФронта(Массив) Экспорт
	
	Результат = Новый Структура;
	Результат.Вставить("ЕстьОшибки", Ложь);
	Результат.Вставить("ТекстОшибки", "");
	
	ТипыОбъектов = ПланыВидовХарактеристик.ПЛ_ТипыОбъектовФронтСистем;
	
	КодыСопоставления = Новый ТаблицаЗначений;
	КолонкиКодыСопоставления = КодыСопоставления.Колонки;
	КолонкиКодыСопоставления.Добавить("ИмяПоляКод");
	КолонкиКодыСопоставления.Добавить("ТипОбъекта");
	КолонкиКодыСопоставления.Добавить("ИмяПоляНаименование");
	КолонкиКодыСопоставления.Добавить("ИмяПоляКодНоменклатуры");
	КолонкиКодыСопоставления.Добавить("ИмяПоляКоличество");
	КолонкиКодыСопоставления.Добавить("ИмяПоляСистема");
	
	
	ДобавитьКодСопоставления(КодыСопоставления, ТипыОбъектов.Номенклатура, "ButtonKey", "ButtonName","FrontSystem", "ItemCode", "QPU");
	
	СтрокаСопоставления = КодыСопоставления.Найти(ТипыОбъектов.Номенклатура, "ТипОбъекта");
	
	СоответствиеСФронтСистемами = РегистрыСведений.ПЛ_СоответствиеСФронтСистемами;
	
	// Обходим массив соответствий
	Для Каждого Соответствие Из Массив Цикл
		
		// Ищем номенклатуру по коду из ItemCode
		КодНоменклатуры = Соответствие[СтрокаСопоставления.ИмяПоляКодНоменклатуры];
		Номенклатура = Справочники.Номенклатура.НайтиПоКоду(КодНоменклатуры);
		
		Если НЕ ЗначениеЗаполнено(Номенклатура) Тогда
			Результат.ЕстьОшибки = Истина;
			Результат.ТекстОшибки = Результат.ТекстОшибки + 
				"Не найдена номенклатура с кодом: " + КодНоменклатуры + Символы.ПС;
			Продолжить; // Пропускаем, если номенклатура не найдена
		КонецЕсли;
		
		//Фронт-система
		Для каждого ЭлементПеречисления Из Метаданные.Перечисления.ПЛ_ТипыФронтСистем.ЗначенияПеречисления Цикл
	        Если ВРег(ЭлементПеречисления.Синоним) = ВРег(Соответствие[СтрокаСопоставления.ИмяПоляСистема]) Тогда
	            ФронтСистема = Перечисления.ПЛ_ТипыФронтСистем[ЭлементПеречисления.Имя];
	            Прервать;
	        КонецЕсли; 
		КонецЦикла;
			
		// Создаем запись в регистре сведений
		НаборЗаписей = СоответствиеСФронтСистемами.СоздатьНаборЗаписей();
		
		// Предполагаем, что измерения регистра включают ТипОбъекта и КодВоФронтСистеме
		НаборЗаписей.Отбор.ТипОбъекта.Установить(ТипыОбъектов.Номенклатура);
		НаборЗаписей.Отбор.ФронтСистема.Установить(ФронтСистема);
		НаборЗаписей.Отбор.Код.Установить(Соответствие[СтрокаСопоставления.ИмяПоляКод]);
		
		// Читаем существующие записи, чтобы не дублировать
		НаборЗаписей.Прочитать();
		
		Если НаборЗаписей.Количество() = 0 Тогда
			// Добавляем новую запись
			НоваяЗапись = НаборЗаписей.Добавить();
		Иначе
			// Обновляем существующую
			НоваяЗапись = НаборЗаписей[0];
		КонецЕсли;
		
		// Заполняем поля записи
		НоваяЗапись.ТипОбъекта = ТипыОбъектов.Номенклатура;
		НоваяЗапись.Код = Соответствие[СтрокаСопоставления.ИмяПоляКод];
		НоваяЗапись.НаименованиеКнопки = Соответствие[СтрокаСопоставления.ИмяПоляНаименование];
		НоваяЗапись.ФронтСистема = ФронтСистема;
		НоваяЗапись.Объект = Номенклатура; // Ссылка на номенклатуру
		НоваяЗапись.Количество = Соответствие[СтрокаСопоставления.ИмяПоляКоличество];
		
		// Записываем набор
		Попытка
			НаборЗаписей.Записать(Истина); // Истина - заменяем существующие записи
		Исключение
			Результат.ЕстьОшибки = Истина;
			
			СтрокаСообщенияОбОшибке = НСтр("ru = 'Загрузка соответсвия из ELMA. Не удалось записать данные для сопоставления для системы %1, тип объекта %2, код %3.
				|Описание ошибки: %4'");
			
			СтрокаСообщенияОбОшибке = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(СтрокаСообщенияОбОшибке,
								ФронтСистема,
								ТипыОбъектов.Номенклатура,
								Соответствие[СтрокаСопоставления.ИмяПоляКод],
								КраткоеПредставлениеОшибки(ИнформацияОбОшибке()));
								
			Результат.ТекстОшибки = Результат.ТекстОшибки + СтрокаСообщенияОбОшибке;					
											
			ЗаписьЖурналаРегистрации("Загрузка соответсвия из ELMA", УровеньЖурналаРегистрации.Ошибка,,, СтрокаСообщенияОбОшибке);

		КонецПопытки;
		
	КонецЦикла;
	
	Возврат Результат;
		
КонецФункции

// Добавляет строку настройки сопоставления полей в таблицу кодов сопоставления.
//
// Параметры:
//  КодыСопоставления      - ТаблицаЗначений - Таблица значений, содержащая
//      настройки сопоставления полей.
//  ТипОбъекта             - ПланВидовХарактеристикСсылка.ПЛ_ТипыОбъектовФронтСистем -
//      Тип объекта сопоставления.
//  ИмяПоляКод             - Строка - Имя поля, содержащего код объекта.
//  ИмяПоляНаименование    - Строка - Имя поля, содержащего наименование объекта.
//  ИмяПоляСистема         - Строка - Имя поля, содержащего наименование системы.
//  ИмяПоляКодНоменклатуры - Строка - Имя поля, содержащего код номенклатуры.
//  ИмяПоляКоличество      - Строка - Имя поля, содержащего количество.
Процедура ДобавитьКодСопоставления(КодыСопоставления, ТипОбъекта, ИмяПоляКод, ИмяПоляНаименование, ИмяПоляСистема, ИмяПоляКодНоменклатуры, ИмяПоляКоличество) Экспорт
	
	НовСтр							= КодыСопоставления.Добавить();
	НовСтр.ТипОбъекта				= ТипОбъекта;
	НовСтр.ИмяПоляКод				= ИмяПоляКод;
	НовСтр.ИмяПоляНаименование		= ИмяПоляНаименование;
	НовСтр.ИмяПоляКодНоменклатуры	= ИмяПоляКодНоменклатуры;
	НовСтр.ИмяПоляСистема			= ИмяПоляСистема;
	НовСтр.ИмяПоляКоличество		= ИмяПоляКоличество;
		
КонецПроцедуры

// Формирует XML-ответ со статусом записи соответствий фронта.
//
// Параметры:
//  Статус       - Число - Код статуса обработки.
//      Значение по умолчанию: 0.
//      Поддерживаемые значения:
//      * 0 - обработка выполнена успешно;
//      * 1 - при обработке возникла ошибка.
//  СтрокаОшибки - Строка - Текст ошибки.
//      Используется при статусе, отличном от 0.
//      Значение по умолчанию: пустая строка.
//
// Возвращаемое значение:
//  Строка - XML-строка ответа.
//
// Описание:
//  В зависимости от переданного статуса формируется XML-ответ
//  с признаком успешной обработки, текстом ошибки или сообщением
//  о неизвестном статусе.
Функция СформироватьСтатусОтвета_ЗаписатьСоответствияФронта(Статус = 0, СтрокаОшибки = "") Экспорт
	
	Если Статус = 0 Тогда 
		
		Результат = "<?xml version=""1.0""?>
						|<Response>
						|	<Status>" + Статус + "</Status>
						|	<Err_String>" + "Все хорошо" + "</Err_String>" + "
						|</Response>";
		
		Возврат Результат;
		
	ИначеЕсли Статус = 1 Тогда
		
		Результат = "<?xml version=""1.0""?>
						|<Response>
						|	<Status>" + Статус + "</Status>
						|	<Err_String>" + СтрокаОшибки + "</Err_String>" + " 
						|</Response>";
		Возврат Результат;
		
	Иначе	
		
		Результат = "<?xml version=""1.0""?>
						|<Response>
						|	<Err_String>" + "Неизвестно" + "</Err_String>" + " 
						|</Response>";
		
		Возврат Результат;
		
	КонецЕсли
	
КонецФункции

