// Отмена приказа в 1С и ЕЛМА при установке пометки удаления
//
// Параметры:
//  ДокументСсылка - ДокументСсылка.УстановкаЦенНоменклатуры
//
Процедура ДокументУстановкаЦенПередУдалением(Документ) Экспорт
	
	Если НЕ Документ.ПометкаУдаления Тогда
		Возврат;
	КонецЕсли;
	
	УстановитьПривилегированныйРежим(Истина);
	
	Попытка
		
		// Шаг 1: Получить статус из регистра
		СтатусДокумента = ПолучитьСтатусДокумента(Документ);
		
		// Если документ не отправлялся в ЕЛМА - тихий выход
		Если СтатусДокумента = Неопределено Тогда
			Возврат;
		КонецЕсли;
		
		// Шаг 2: Проверка, уже отменен ли приказ
		Если СтатусДокумента.Статус = Перечисления.MRS_СтатусыСинхронизацииELMA.Отменен Тогда
			Возврат;
		КонецЕсли;
		
		// Шаг 3: Получение УИДЕЛМА
		УИДЕЛМА = СтатусДокумента.УИДЕЛМА;
		
		// Если УИДЕЛМА не заполнен - только локальная отмена
		Если ПустаяСтрока(УИДЕЛМА) Тогда
			
			ЛокальнаяОтменаПриказа(Документ, "Документ локально отменен в 1С (УИДЕЛМА отсутствует)");
			Возврат;
			
		КонецЕсли;
		
		// Шаг 4: Авторизация в ЕЛМА
		РезультатАвторизации = АвторизоватьсяВЕЛМА();
		
		Если НЕ РезультатАвторизации.Успех Тогда
			
			ТекстОшибки = "Не удалось авторизоваться в ЕЛМА для отмены приказа: " + РезультатАвторизации.ТекстОшибки;
			ЗаписатьЛог(ТекстОшибки, УровеньЖурналаРегистрации.Ошибка);
			ЛокальнаяОтменаПриказа(Документ, ТекстОшибки, Истина);
			Возврат;
			
		КонецЕсли;
		
		AuthToken = РезультатАвторизации.Токен;
		
		// Шаг 5: Отправка запроса отмены в ЕЛМА
		РезультатОтмены = ОтменитьПриказВЕЛМА(УИДЕЛМА, AuthToken);
		
		// Шаг 6: Обработка результата отмены
		Если РезультатОтмены.Успех Тогда
			
			// Успешная отмена - обновление статуса
			ОбновитьСтатусДокументаПриОтмене(Документ, Перечисления.MRS_СтатусыСинхронизацииELMA.Отменен, "");
			ЗаписатьЛог(СтрШаблон("Документ %1 успешно отменен в ЕЛМА и 1С", Документ.Ссылка), 
				УровеньЖурналаРегистрации.Информация);
			
		Иначе
			
			// Ошибка отмены в ЕЛМА - локальная отмена со статусом "ТребуетВнимания"
			ТекстОшибки = "Ошибка отправки запроса отмены в ЕЛМА: " + РезультатОтмены.ТекстОшибки;
			ЗаписатьЛог(ТекстОшибки, УровеньЖурналаРегистрации.Ошибка);
			
			ЗаписатьЛог(СтрШаблон("JSON запроса отмены: %1", РезультатОтмены.JSONЗапроса), 
				УровеньЖурналаРегистрации.Ошибка);
			
			Если ЗначениеЗаполнено(РезультатОтмены.JSONОтвета) Тогда
				ЗаписатьЛог(СтрШаблон("JSON ответа от ЕЛМА: %1", РезультатОтмены.JSONОтвета), 
					УровеньЖурналаРегистрации.Ошибка);
			КонецЕсли;
			
			ЛокальнаяОтменаПриказа(Документ, ТекстОшибки, Истина);
			
		КонецЕсли;
		
	Исключение
		
		ЗаписатьЛог("Критическая ошибка при отмене приказа: " + ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()), 
			УровеньЖурналаРегистрации.Ошибка);
		
	КонецПопытки;
	
	УстановитьПривилегированныйРежим(Ложь);
	
КонецПроцедуры

// Выполняет локальную отмену приказа в 1С (обновление статуса в регистре)
//
// Параметры:
//  ДокументСсылка - ДокументСсылка.УстановкаЦенНоменклатуры
//  ТекстСообщения - Строка - текст для логирования
//  ТребуетВнимания - Булево - устанавливать статус "ТребуетВнимания" вместо "Отменен"
//
Процедура ЛокальнаяОтменаПриказа(Документ, ТекстСообщения, ТребуетВнимания = Ложь)
	
	НовыйСтатус = ?(ТребуетВнимания, 
		Перечисления.MRS_СтатусыСинхронизацииELMA.ТребуетВнимания, 
		Перечисления.MRS_СтатусыСинхронизацииELMA.Отменен);
	
	ОбновитьСтатусДокументаПриОтмене(Документ, НовыйСтатус, ТекстСообщения);
	
	УровеньЛога = ?(ТребуетВнимания, УровеньЖурналаРегистрации.Предупреждение, УровеньЖурналаРегистрации.Информация);
	ЗаписатьЛог(СтрШаблон("Документ %1: %2", Документ.Ссылка, ТекстСообщения), УровеньЛога);
	
	Если ТребуетВнимания Тогда
		ЗаписатьЛог(СтрШаблон("ВНИМАНИЕ: Процесс в ЕЛМА может оставаться активным. " + 
			"Требуется ручная проверка и отмена в системе ЕЛМА!"), УровеньЖурналаРегистрации.Предупреждение);
	КонецЕсли;
	
КонецПроцедуры

// Обновляет статус документа в регистре MRS_ПроцессыELMA при отмене
//
// Параметры:
//  ДокументСсылка - ДокументСсылка.УстановкаЦенНоменклатуры
//  НовыйСтатус - ПеречислениеСсылка.MRS_СтатусыСинхронизацииELMA
//  ТекстОшибки - Строка - текст ошибки (если есть)
//
Процедура ОбновитьСтатусДокументаПриОтмене(Документ, НовыйСтатус, ТекстОшибки)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ПроцессыЕЛМА.UidДокумента1С КАК UidДокумента1С
		|ИЗ
		|	РегистрСведений.MRS_ПроцессыELMA КАК ПроцессыЕЛМА
		|ГДЕ
		|	ПроцессыЕЛМА.Документ1С = &Документ1С
		|	И (ПроцессыЕЛМА.ВидПроцесса = &ВидПроцесса
		|		ИЛИ ПроцессыЕЛМА.ВидПроцесса = """")";
	
	Запрос.УстановитьПараметр("Документ1С", Документ.Ссылка);
	Запрос.УстановитьПараметр("ВидПроцесса", ВидПроцессаПриказЕЛМА());
	
	РезультатЗапроса = Запрос.Выполнить();
	Выборка = РезультатЗапроса.Выбрать();
	
	Если Выборка.Следующий() Тогда
		
		МенеджерЗаписи = РегистрыСведений.MRS_ПроцессыELMA.СоздатьМенеджерЗаписи();
		МенеджерЗаписи.UidДокумента1С = Выборка.UidДокумента1С;
		МенеджерЗаписи.Прочитать();
		
		Если МенеджерЗаписи.Выбран() Тогда
			
			МенеджерЗаписи.Статус = НовыйСтатус;
			МенеджерЗаписи.ДатаПоследнегоОбновления = ТекущаяДатаСеанса();
			
			Если ЗначениеЗаполнено(ТекстОшибки) Тогда
				МенеджерЗаписи.ТекстОшибки = ТекстОшибки;
			КонецЕсли;
			
			МенеджерЗаписи.Записать();
			
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область ФормированиеДанных

Функция СформироватьJSONСтатусаЗаказаПоставщикуЕЛМА(ДокументПриобретения)

	ДокументОбъект = ОбъектПриобретенияТоваровУслуг(ДокументПриобретения);
	Если ДокументОбъект = Неопределено Тогда
		ВызватьИсключение "Передан не документ ПриобретениеТоваровУслуг";
	КонецЕсли;

	ЗаказПоставщику = ЕдинственныйЗаказПоставщикуПриобретения(ДокументОбъект);
	Если НЕ ЗначениеЗаполнено(ЗаказПоставщику) Тогда
		ВызватьИсключение "В ПТУ не найден единственный заказ поставщику";
	КонецЕсли;

	ДанныеЗапроса = Новый Структура;
	ДанныеЗапроса.Вставить("request_id", УИДСсылкиДляЕЛМА(ЗаказПоставщику));
	ДанныеЗапроса.Вставить("need_data", ДанныеПотребностейСтатусаЗаказаПоставщикуЕЛМА(
		ДокументОбъект,
		ЗаказПоставщику));

	Контекст = Новый Структура;
	Контекст.Вставить("request_data", СтруктураВСтрокуJSONЕЛМА(ДанныеЗапроса));

	ТелоЗапроса = Новый Структура;
	ТелоЗапроса.Вставить("context", Контекст);

	Возврат СтруктураВСтрокуJSONЕЛМА(ТелоЗапроса);

КонецФункции

Функция ДанныеПотребностейСтатусаЗаказаПоставщикуЕЛМА(ДокументПриобретения, ЗаказПоставщику)

	ЗаказОбъект = ЗаказПоставщику.ПолучитьОбъект();
	КодыСтрокЗаказа = КодыСтрокЗаказаПоставщикуЕЛМА(ЗаказОбъект);
	ДанныеФакта = ФактыПриобретенияЗаказаПоставщикуЕЛМА(ДокументПриобретения, ЗаказПоставщику, КодыСтрокЗаказа);

	ДанныеПотребностей = Новый Массив;

	Для Каждого СтрокаЗаказа Из ЗаказОбъект.Товары Цикл

		Факт = ДанныеФакта.ФактыПоКодамСтрок[СтрокаЗаказа.КодСтроки];
		Если Факт = Неопределено Тогда
			Факт = ПустойФактСтрокиСтатусаЕЛМА();
		КонецЕсли;

		ДанныеПотребностей.Добавить(ПотребностьСтатусаПоСтрокеЗаказаЕЛМА(СтрокаЗаказа, Факт));

	КонецЦикла;

	Для Каждого СтрокаСверхЗаказа Из ДанныеФакта.СтрокиСверхЗаказа Цикл
		ДанныеПотребностей.Добавить(ПотребностьСтатусаПоСтрокеПриобретенияЕЛМА(СтрокаСверхЗаказа));
	КонецЦикла;

	Возврат ДанныеПотребностей;

КонецФункции

Функция ФактыПриобретенияЗаказаПоставщикуЕЛМА(ДокументПриобретения, ЗаказПоставщику, КодыСтрокЗаказа)

	Результат = Новый Структура;
	Результат.Вставить("ФактыПоКодамСтрок", Новый Соответствие);
	Результат.Вставить("СтрокиСверхЗаказа", Новый Массив);

	Для Каждого СтрокаТоваров Из ДокументПриобретения.Товары Цикл

		ЗаказСтроки = СтрокаТоваров.ЗаказПоставщику;
		Если НЕ ЗначениеЗаполнено(ЗаказСтроки) Тогда
			ЗаказСтроки = ДокументПриобретения.ЗаказПоставщику;
		КонецЕсли;

		Если ЗаказСтроки <> ЗаказПоставщику Тогда
			Продолжить;
		КонецЕсли;

		Если НЕ ЗначениеЗаполнено(СтрокаТоваров.КодСтроки)
			ИЛИ КодыСтрокЗаказа[СтрокаТоваров.КодСтроки] = Неопределено Тогда

			Результат.СтрокиСверхЗаказа.Добавить(СтрокаТоваров);
			Продолжить;

		КонецЕсли;

		Факт = Результат.ФактыПоКодамСтрок[СтрокаТоваров.КодСтроки];
		Если Факт = Неопределено Тогда
			Факт = ПустойФактСтрокиСтатусаЕЛМА();
			Результат.ФактыПоКодамСтрок.Вставить(СтрокаТоваров.КодСтроки, Факт);
		КонецЕсли;

		Факт.Количество = Факт.Количество + СтрокаТоваров.Количество;
		Факт.Сумма = Факт.Сумма + СтрокаТоваров.Сумма;
		Факт.СуммаСНДС = Факт.СуммаСНДС + СтрокаТоваров.СуммаСНДС;

	КонецЦикла;

	Возврат Результат;

КонецФункции

Функция КодыСтрокЗаказаПоставщикуЕЛМА(ЗаказПоставщику)

	КодыСтрок = Новый Соответствие;

	Для Каждого СтрокаТоваров Из ЗаказПоставщику.Товары Цикл

		Если ЗначениеЗаполнено(СтрокаТоваров.КодСтроки) Тогда
			КодыСтрок.Вставить(СтрокаТоваров.КодСтроки, Истина);
		КонецЕсли;

	КонецЦикла;

	Возврат КодыСтрок;

КонецФункции

Функция ПотребностьСтатусаПоСтрокеЗаказаЕЛМА(СтрокаЗаказа, Факт)

	Потребность = Новый Структура;
	Потребность.Вставить("name", Строка(СтрокаЗаказа.Номенклатура));
	Потребность.Вставить("count", Факт.Количество);
	Потребность.Вставить("measurement_unit", Строка(СтрокаЗаказа.Упаковка));
	Потребность.Вставить("price_for_measurement_unit", ЦенаЗаЕдиницуСтатусаЕЛМА(Факт.Количество, Факт.Сумма));
	Потребность.Вставить("vat_rate", Строка(СтрокаЗаказа.СтавкаНДС));
	Потребность.Вставить("price_with_vat", Факт.СуммаСНДС);
	Потребность.Вставить("warehouse_receiver_uid", УИДСсылкиДляЕЛМА(СтрокаЗаказа.Склад));
	Потребность.Вставить("nomenclature_uid", УИДСсылкиДляЕЛМА(СтрокаЗаказа.Номенклатура));

	Возврат Потребность;

КонецФункции

Функция ПотребностьСтатусаПоСтрокеПриобретенияЕЛМА(СтрокаПриобретения)

	Потребность = Новый Структура;
	Потребность.Вставить("name", Строка(СтрокаПриобретения.Номенклатура));
	Потребность.Вставить("count", СтрокаПриобретения.Количество);
	Потребность.Вставить("measurement_unit", Строка(СтрокаПриобретения.Упаковка));
	Потребность.Вставить(
		"price_for_measurement_unit",
		ЦенаЗаЕдиницуСтатусаЕЛМА(СтрокаПриобретения.Количество, СтрокаПриобретения.Сумма));
	Потребность.Вставить("vat_rate", Строка(СтрокаПриобретения.СтавкаНДС));
	Потребность.Вставить("price_with_vat", СтрокаПриобретения.СуммаСНДС);
	Потребность.Вставить("warehouse_receiver_uid", УИДСсылкиДляЕЛМА(СтрокаПриобретения.Склад));
	Потребность.Вставить("nomenclature_uid", УИДСсылкиДляЕЛМА(СтрокаПриобретения.Номенклатура));

	Возврат Потребность;

КонецФункции

Функция ПустойФактСтрокиСтатусаЕЛМА()

	Возврат Новый Структура("Количество, Сумма, СуммаСНДС", 0, 0, 0);

КонецФункции

Функция ЦенаЗаЕдиницуСтатусаЕЛМА(Количество, Сумма)

	Если Количество = 0 Тогда
		Возврат 0;
	КонецЕсли;

	Возврат Окр(Сумма / Количество, 2);

КонецФункции

Функция ОбъектПриобретенияТоваровУслуг(ДокументПриобретения)

	Если ТипЗнч(ДокументПриобретения) = Тип("ДокументОбъект.ПриобретениеТоваровУслуг") Тогда
		Возврат ДокументПриобретения;
	КонецЕсли;

	Если ТипЗнч(ДокументПриобретения) = Тип("ДокументСсылка.ПриобретениеТоваровУслуг") Тогда
		Возврат ДокументПриобретения.ПолучитьОбъект();
	КонецЕсли;

	Возврат Неопределено;

КонецФункции

Функция ЕдинственныйЗаказПоставщикуПриобретения(ДокументПриобретения)

	ЗаказыПоставщику = Новый Соответствие;

	Если ЗначениеЗаполнено(ДокументПриобретения.ЗаказПоставщику) Тогда
		ЗаказыПоставщику.Вставить(ДокументПриобретения.ЗаказПоставщику, Истина);
	КонецЕсли;

	Для Каждого СтрокаТоваров Из ДокументПриобретения.Товары Цикл

		Если ЗначениеЗаполнено(СтрокаТоваров.ЗаказПоставщику) Тогда
			ЗаказыПоставщику.Вставить(СтрокаТоваров.ЗаказПоставщику, Истина);
		КонецЕсли;

	КонецЦикла;

	Если ЗаказыПоставщику.Количество() <> 1 Тогда
		Возврат Неопределено;
	КонецЕсли;

	Для Каждого ЭлементЗаказа Из ЗаказыПоставщику Цикл
		Возврат ЭлементЗаказа.Ключ;
	КонецЦикла;

	Возврат Неопределено;

КонецФункции

Функция ЭтоЗаказПоставщикуЕЛМА(ЗаказПоставщику)

	УИДЗаказаПоставщику = УИДСсылкиДляЕЛМА(ЗаказПоставщику);
	Если ПустаяСтрока(УИДЗаказаПоставщику) Тогда
		Возврат Ложь;
	КонецЕсли;

	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	ПроцессыЕЛМА.UidДокумента1С КАК UidДокумента1С
		|ИЗ
		|	РегистрСведений.MRS_ПроцессыELMA КАК ПроцессыЕЛМА
		|ГДЕ
		|	ПроцессыЕЛМА.UidДокумента1С = &УИДЗаказаПоставщику
		|	И ПроцессыЕЛМА.ВидПроцесса = &ВидПроцесса";

	Запрос.УстановитьПараметр("УИДЗаказаПоставщику", УИДЗаказаПоставщику);
	Запрос.УстановитьПараметр("ВидПроцесса", ВидПроцессаСтатусЗаказаПоставщикуЕЛМА());

	РезультатЗапроса = Запрос.Выполнить();

	Возврат НЕ РезультатЗапроса.Пустой();

КонецФункции

Функция СтруктураВСтрокуJSONЕЛМА(Данные)

	ЗаписьJSON = Новый ЗаписьJSON;
	ЗаписьJSON.УстановитьСтроку();
	ЗаписатьJSON(ЗаписьJSON, Данные);

	Возврат ЗаписьJSON.Закрыть();

КонецФункции

// Формирует JSON-структуру для отправки в ЕЛМА
//
// Параметры:
//  ДокументСсылка - ДокументСсылка.УстановкаЦенНоменклатуры
//  ПараметрыПриказа - Структура - параметры из формы
//
// Возвращаемое значение:
//  Структура - данные для отправки в ЕЛМА
//
Функция СформироватьJSONДляЕЛМА(ДокументСсылка, ПараметрыПриказа) Экспорт
	
	// Чтение документа
	Документ = ДокументСсылка.ПолучитьОбъект();
	
	// Получение вида цены из первой строки табличной части
	Если Документ.Товары.Количество() = 0 Тогда
		ВызватьИсключение "В документе отсутствуют строки с ценами";
	КонецЕсли;
	
	ВидЦены = Документ.ВидыЦен[0].ВидЦены;
	
	// Получение Uid организации из параметров приказа
	UidОрганизации = ПараметрыПриказа.ГуидЕлмаОрганизации;
	
	// Генерация UID документа для ЕЛМА (для callback)
	UidДокумента1С = ГенерироватьUidДокумента1С(ДокументСсылка);
	
	// Получение Uid инициатора (текущего пользователя) - СТРОКА, не объект!
	InitiatorString = ПолучитьUidТекущегоПользователяЕЛМА(); 
	
	// Формирование DecreeHeadline из параметров приказа
	DecreeHeadline = ПараметрыПриказа.Тема;
	
	// Формирование DecreeContent
	DecreeContent = СформироватьDecreeContent(ДокументСсылка);
	
	// Формирование Word-файла приказа
	ДвоичныеДанныеWord = СформироватьПриказЕЛМА(ДокументСсылка, ПараметрыПриказа);
	
	Если ДвоичныеДанныеWord = Неопределено Тогда
		ВызватьИсключение "Не удалось сформировать Word-файл приказа";
	КонецЕсли;
	
	FileBase64 = Base64Строка(ДвоичныеДанныеWord);
	
	// Получение констант
	//ProcessToken = ПЛ_ДополнительныеКонстантыПовтИсп.ВернутьДополнительнуюКонстанту("MRS_ProcessTokenЕЛМА");  TODO
	ProcessToken = "489d2dbf-0017-458e-8edb-f5d5aa70b00f";
	//DecreeTypeUid = ПЛ_ДополнительныеКонстантыПовтИсп.ВернутьДополнительнуюКонстанту("MRS_DecreeTypeУИДЕЛМА"); TODO
	DecreeTypeUid = "571c78cc-baa0-4529-a00f-8e6c65790ae7";
	
	// Формирование структуры Context
	Context = Новый Структура;
	
	// Organization с ID1C (UID документа 1С) и Uid (Uid организации в ЕЛМА)
	OrganizationObj = Новый Структура;
	OrganizationObj.Вставить("Uid", UidОрганизации);  // Uid организации в ЕЛМА
	Context.Вставить("Organization", OrganizationObj);
	Context.Вставить("Uid1c", UidДокумента1С); // UID документа 1С для callback

	// InitiatorString - СТРОКА, не объект {Uid: "..."}!
	Context.Вставить("InitiatorString", InitiatorString);
	
	Context.Вставить("DecreeType", Новый Структура("Uid", DecreeTypeUid));
	Context.Вставить("DecreeHeadline", DecreeHeadline);
	Context.Вставить("Preamble", ПараметрыПриказа.Цель);
	Context.Вставить("DecreeContent", DecreeContent);
	Context.Вставить("StartDate", XMLСтрока(ПараметрыПриказа.ДатаНачалаДействия)); // ISO 8601
	
	// UserString - тот же что InitiatorString (для ознакомления)
	Context.Вставить("UserString", InitiatorString);
	
	Context.Вставить("FileDecree", FileBase64);
	
	// approval - нужно ли согласование процесса из-за отклонений по ценам
	Context.Вставить("approval", ОпределитьНеобходимостьСогласования(ДокументСсылка));
	
	// Формирование итоговой структуры
	Результат = Новый Структура;
	Результат.Вставить("ProcessToken", ProcessToken);
	Результат.Вставить("Context", Context);
	
	Возврат Результат;
	
КонецФункции

// Формирует текст приказа (DecreeContent)
//
// Параметры:
//  ДокументСсылка - ДокументСсылка.УстановкаЦенНоменклатуры
//
// Возвращаемое значение:
//  Строка - текст приказа
//
Функция СформироватьDecreeContent(ДокументСсылка) Экспорт
	
	ТекстПриказа = 
		"1. Установить цены согласно приложению №1." + Символы.ПС +
		"2. Контроль за внесением изменений возложить на финансового контролера." + Символы.ПС +
		"3. Контроль за исполнением приказа возложить на директора департамента.";
	
	Возврат ТекстПриказа;
	
КонецФункции

// Определяет необходимость согласования приказа на основе сравнения цены с расчетной
// Логика: если устанавливаемая цена меньше расчетной - требуется согласование
//
// Параметры:
//  ДокументСсылка - ДокументСсылка.УстановкаЦенНоменклатуры - документ для проверки
//
// Возвращаемое значение:
//  Строка - "True" если требуется согласование, "False" если нет
//
Функция ОпределитьНеобходимостьСогласования(ДокументСсылка) Экспорт
	
	// Получаем данные документа и расчетные цены
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	питУдаленныеКассыВидыМеню.Ссылка КАК Ссылка,
		|	питУдаленныеКассыMRS_КостПродаж.ПроцентНаценки КАК ПроцентНаценки,
		|	питУдаленныеКассыMRS_КостПродаж.Ссылка.Организация КАК Организация,
		|	питУдаленныеКассыMRS_КостПродаж.Ссылка.СкладРеализации КАК СкладРеализации,
		|	питУдаленныеКассыВидыМеню.ВидМеню КАК ВидМеню
		|ПОМЕСТИТЬ ВТ_Наценка
		|ИЗ
		|	ПланОбмена.питУдаленныеКассы.ВидыМеню КАК питУдаленныеКассыВидыМеню
		|		ЛЕВОЕ СОЕДИНЕНИЕ ПланОбмена.питУдаленныеКассы.MRS_КостПродаж КАК питУдаленныеКассыMRS_КостПродаж
		|		ПО (питУдаленныеКассыВидыМеню.Ссылка = питУдаленныеКассыMRS_КостПродаж.Ссылка)
		|ГДЕ
		|	питУдаленныеКассыВидыМеню.Ссылка.ВидЦен В
		|			(ВЫБРАТЬ РАЗЛИЧНЫЕ
		|				УстановкаЦенНоменклатурыВидыЦен.ВидЦены
		|			ИЗ
		|				Документ.УстановкаЦенНоменклатуры.ВидыЦен КАК УстановкаЦенНоменклатурыВидыЦен
		|			ГДЕ
		|				УстановкаЦенНоменклатурыВидыЦен.Ссылка = &Документ)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	УстановкаЦен.Номенклатура КАК Номенклатура,
		|	УстановкаЦен.Цена КАК УстановленнаяЦена,
		|	СтоимостьТоваровСрезПоследних.Стоимость * 1.2 * (1 + ЕСТЬNULL(ВТ_Наценка.ПроцентНаценки, 0) / 100) КАК РасчетнаяЦена
		|ИЗ
		|	Документ.УстановкаЦенНоменклатуры.Товары КАК УстановкаЦен
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_Наценка КАК ВТ_Наценка
		|		ПО (ИСТИНА)
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.СтоимостьТоваров.СрезПоследних(&ТекущаяДата, ) КАК СтоимостьТоваровСрезПоследних
		|		ПО (УстановкаЦен.Номенклатура = СтоимостьТоваровСрезПоследних.АналитикаУчетаНоменклатуры.Номенклатура)
		|			И (СтоимостьТоваровСрезПоследних.АналитикаУчетаНоменклатуры.МестоХранения = ВТ_Наценка.СкладРеализации)
		|			И (СтоимостьТоваровСрезПоследних.Организация = ВТ_Наценка.Организация)
		|ГДЕ
		|	УстановкаЦен.Ссылка = &Документ";
	
	Запрос.УстановитьПараметр("Документ", ДокументСсылка);
	Запрос.УстановитьПараметр("ТекущаяДата", ТекущаяДатаСеанса());
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	// Проверяем каждую позицию: если установленная цена < расчетной - требуется согласование
	Пока Выборка.Следующий() Цикл
		
		РасчетнаяЦена = Выборка.РасчетнаяЦена;
		УстановленнаяЦена = Выборка.УстановленнаяЦена;
		
		// Если расчетная цена не определена (нет стоимости) - пропускаем
		Если НЕ ЗначениеЗаполнено(РасчетнаяЦена) Тогда
			Продолжить;
		КонецЕсли;
		
		// Если установленная цена меньше расчетной - требуется согласование
		Если УстановленнаяЦена < РасчетнаяЦена Тогда
			
			ЗаписатьЛог(СтрШаблон(
				"Для документа %1 требуется согласование: номенклатура %2, установленная цена %3 < расчетной цены %4", 
				ДокументСсылка, Выборка.Номенклатура, УстановленнаяЦена, РасчетнаяЦена), 
				УровеньЖурналаРегистрации.Информация);
			
			Возврат "True";
			
		КонецЕсли;
		
	КонецЦикла;
	
	// Если все цены >= расчетных - согласование не требуется
	Возврат "False";
	
КонецФункции

// Проверяет наличие цен ниже расчетной себестоимости в документе
// Используется для информирования пользователя перед записью документа
//
// Параметры:
//  ДокументСсылка - ДокументСсылка.УстановкаЦенНоменклатуры - документ для проверки
//
// Возвращаемое значение:
//  Структура:
//   * НайденыОтклонения - Булево - Истина если найдены цены ниже себестоимости
//   * СписокПозиций - Массив из Структура - список позиций с отклонениями:
//     ** Номенклатура - СправочникСсылка.Номенклатура
//     ** УстановленнаяЦена - Число
//     ** РасчетнаяЦена - Число
//     ** Отклонение - Число
//     ** ОтклонениеПроцент - Число
//
Функция ПроверитьЦеныНижеКоста(ДанныеФормы) Экспорт
	
	Результат = Новый Структура;
	Результат.Вставить("НайденыОтклонения", Ложь);
	Результат.Вставить("СписокПозиций", Новый Массив);
	
	// Получаем данные документа и расчетные цены (используем ту же логику что в ОпределитьНеобходимостьСогласования)
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	питУдаленныеКассыВидыМеню.Ссылка КАК Ссылка,
	|	питУдаленныеКассыMRS_КостПродаж.ПроцентНаценки КАК ПроцентНаценки,
	|	питУдаленныеКассыMRS_КостПродаж.Ссылка.Организация КАК Организация,
	|	питУдаленныеКассыMRS_КостПродаж.Ссылка.СкладРеализации КАК СкладРеализации,
	|	питУдаленныеКассыВидыМеню.ВидМеню КАК ВидМеню,
	|	питУдаленныеКассыВидыМеню.Ссылка.Подразделение КАК Подразделение
	|ПОМЕСТИТЬ ВТ_Наценка
	|ИЗ
	|	ПланОбмена.питУдаленныеКассы.ВидыМеню КАК питУдаленныеКассыВидыМеню
	|		ЛЕВОЕ СОЕДИНЕНИЕ ПланОбмена.питУдаленныеКассы.MRS_КостПродаж КАК питУдаленныеКассыMRS_КостПродаж
	|		ПО питУдаленныеКассыВидыМеню.Ссылка = питУдаленныеКассыMRS_КостПродаж.Ссылка
	|ГДЕ
	|	питУдаленныеКассыВидыМеню.Ссылка.ВидЦен = &ВидЦены
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	питМеню.Номенклатура КАК Номенклатура,
	|	питМеню.MRS_СтавкаНДС КАК MRS_СтавкаНДС
	|ПОМЕСТИТЬ ВТ_Номенклатура
	|ИЗ
	|	Справочник.питМеню КАК питМеню
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ_Наценка КАК ВТ_Наценка
	|		ПО питМеню.Владелец = ВТ_Наценка.ВидМеню
	|ГДЕ
	|	питМеню.Номенклатура В(&МассивНоменклатуры)
	|	И НЕ питМеню.ЭтоГруппа
	|	И питМеню.Номенклатура <> ЗНАЧЕНИЕ(Справочник.Номенклатура.ПустаяСсылка)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	СтоимостьТоваровСрезПоследних.АналитикаУчетаНоменклатуры.Номенклатура КАК Номенклатура,
	|	ВТ_Наценка.Организация КАК Организация,
	|	ВТ_Наценка.СкладРеализации КАК СкладРеализации,
	|	ВТ_Наценка.Подразделение КАК Подразделение,
	|	СтоимостьТоваровСрезПоследних.Стоимость КАК Стоимость
	|ПОМЕСТИТЬ ВТ_СтоимостьПоСкладу
	|ИЗ
	|	РегистрСведений.СтоимостьТоваров.СрезПоследних(&ТекущаяДата, ) КАК СтоимостьТоваровСрезПоследних
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ_Номенклатура КАК ВТ_Номенклатура
	|		ПО СтоимостьТоваровСрезПоследних.АналитикаУчетаНоменклатуры.Номенклатура = ВТ_Номенклатура.Номенклатура
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ_Наценка КАК ВТ_Наценка
	|		ПО СтоимостьТоваровСрезПоследних.АналитикаУчетаНоменклатуры.МестоХранения = ВТ_Наценка.СкладРеализации
	|			И СтоимостьТоваровСрезПоследних.Организация = ВТ_Наценка.Организация
	|ГДЕ
	|	СтоимостьТоваровСрезПоследних.Стоимость <> 0
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	СтоимостьТоваров.АналитикаУчетаНоменклатуры.Номенклатура КАК Номенклатура,
	|	ВТ_Наценка.Организация КАК Организация,
	|	ВТ_Наценка.СкладРеализации КАК СкладРеализации,
	|	ВТ_Наценка.Подразделение КАК Подразделение,
	|	СтоимостьТоваров.Стоимость КАК Стоимость
	|ПОМЕСТИТЬ ВТ_СтоимостьПоПодразделению
	|ИЗ
	|	РегистрСведений.СтоимостьТоваров КАК СтоимостьТоваров
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
	|			СтоимостьТоваров.АналитикаУчетаНоменклатуры.Номенклатура КАК Номенклатура,
	|			СтоимостьТоваров.АналитикаУчетаНоменклатуры.Подразделение КАК Подразделение,
	|			СтоимостьТоваров.Организация КАК Организация,
	|			МАКСИМУМ(СтоимостьТоваров.Период) КАК Период
	|		ИЗ
	|			РегистрСведений.СтоимостьТоваров КАК СтоимостьТоваров
	|				ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ_Номенклатура КАК ВТ_Номенклатура
	|				ПО СтоимостьТоваров.АналитикаУчетаНоменклатуры.Номенклатура = ВТ_Номенклатура.Номенклатура
	|		ГДЕ
	|			СтоимостьТоваров.Период <= &ТекущаяДата
	|			И СтоимостьТоваров.Стоимость <> 0
	|		
	|		СГРУППИРОВАТЬ ПО
	|			СтоимостьТоваров.АналитикаУчетаНоменклатуры.Номенклатура,
	|			СтоимостьТоваров.АналитикаУчетаНоменклатуры.Подразделение,
	|			СтоимостьТоваров.Организация) КАК ПоследниеЗаписи
	|		ПО СтоимостьТоваров.АналитикаУчетаНоменклатуры.Номенклатура = ПоследниеЗаписи.Номенклатура
	|			И СтоимостьТоваров.АналитикаУчетаНоменклатуры.Подразделение = ПоследниеЗаписи.Подразделение
	|			И СтоимостьТоваров.Организация = ПоследниеЗаписи.Организация
	|			И СтоимостьТоваров.Период = ПоследниеЗаписи.Период
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ_Наценка КАК ВТ_Наценка
	|		ПО СтоимостьТоваров.АналитикаУчетаНоменклатуры.Подразделение = ВТ_Наценка.Подразделение
	|			И СтоимостьТоваров.Организация = ВТ_Наценка.Организация
	|ГДЕ
	|	СтоимостьТоваров.Стоимость <> 0
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	СтоимостьТоваров.АналитикаУчетаНоменклатуры.Номенклатура КАК Номенклатура,
	|	ВТ_Наценка.Организация КАК Организация,
	|	ВТ_Наценка.СкладРеализации КАК СкладРеализации,
	|	ВТ_Наценка.Подразделение КАК Подразделение,
	|	СтоимостьТоваров.Стоимость КАК Стоимость
	|ПОМЕСТИТЬ ВТ_СтоимостьПоОрганизации
	|ИЗ
	|	РегистрСведений.СтоимостьТоваров КАК СтоимостьТоваров
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
	|			СтоимостьТоваров.АналитикаУчетаНоменклатуры.Номенклатура КАК Номенклатура,
	|			СтоимостьТоваров.Организация КАК Организация,
	|			МАКСИМУМ(СтоимостьТоваров.Период) КАК Период
	|		ИЗ
	|			РегистрСведений.СтоимостьТоваров КАК СтоимостьТоваров
	|				ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ_Номенклатура КАК ВТ_Номенклатура
	|				ПО СтоимостьТоваров.АналитикаУчетаНоменклатуры.Номенклатура = ВТ_Номенклатура.Номенклатура
	|		ГДЕ
	|			СтоимостьТоваров.Период <= &ТекущаяДата
	|			И СтоимостьТоваров.Стоимость <> 0
	|		
	|		СГРУППИРОВАТЬ ПО
	|			СтоимостьТоваров.АналитикаУчетаНоменклатуры.Номенклатура,
	|			СтоимостьТоваров.Организация) КАК ПоследниеЗаписи
	|		ПО СтоимостьТоваров.АналитикаУчетаНоменклатуры.Номенклатура = ПоследниеЗаписи.Номенклатура
	|			И СтоимостьТоваров.Организация = ПоследниеЗаписи.Организация
	|			И СтоимостьТоваров.Период = ПоследниеЗаписи.Период
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ_Наценка КАК ВТ_Наценка
	|		ПО СтоимостьТоваров.Организация = ВТ_Наценка.Организация
	|ГДЕ
	|	СтоимостьТоваров.Стоимость <> 0
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Закупки.АналитикаУчетаНоменклатуры.Номенклатура КАК Номенклатура,
	|	ВТ_Наценка.Организация КАК Организация,
	|	ВТ_Наценка.СкладРеализации КАК СкладРеализации,
	|	ВТ_Наценка.Подразделение КАК Подразделение,
	|	Закупки.Стоимость / Закупки.Количество КАК Стоимость
	|ПОМЕСТИТЬ ВТ_ЗакупкиТекМесяцСклад
	|ИЗ
	|	РегистрНакопления.Закупки КАК Закупки
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
	|			Закупки.АналитикаУчетаНоменклатуры.Номенклатура КАК Номенклатура,
	|			Закупки.Склад КАК Склад,
	|			МАКСИМУМ(Закупки.Период) КАК Период
	|		ИЗ
	|			РегистрНакопления.Закупки КАК Закупки
	|				ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ_Номенклатура КАК ВТ_Номенклатура
	|				ПО Закупки.АналитикаУчетаНоменклатуры.Номенклатура = ВТ_Номенклатура.Номенклатура
	|		ГДЕ
	|			Закупки.Стоимость <> 0
	|			И Закупки.Количество <> 0
	|			И Закупки.Регистратор ССЫЛКА Документ.ПриобретениеТоваровУслуг
	|			И Закупки.Период >= НАЧАЛОПЕРИОДА(&ТекущаяДата, МЕСЯЦ)
	|			И Закупки.Период < ДОБАВИТЬКДАТЕ(КОНЕЦПЕРИОДА(&ТекущаяДата, МЕСЯЦ), СЕКУНДА, 1)
	|		
	|		СГРУППИРОВАТЬ ПО
	|			Закупки.АналитикаУчетаНоменклатуры.Номенклатура,
	|			Закупки.Склад) КАК ПоследниеЗакупки
	|		ПО Закупки.АналитикаУчетаНоменклатуры.Номенклатура = ПоследниеЗакупки.Номенклатура
	|			И Закупки.Склад = ПоследниеЗакупки.Склад
	|			И Закупки.Период = ПоследниеЗакупки.Период
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ_Наценка КАК ВТ_Наценка
	|		ПО Закупки.Склад = ВТ_Наценка.СкладРеализации
	|ГДЕ
	|	Закупки.Стоимость <> 0
	|	И Закупки.Количество <> 0
	|	И Закупки.Регистратор ССЫЛКА Документ.ПриобретениеТоваровУслуг
	|	И Закупки.Период >= НАЧАЛОПЕРИОДА(&ТекущаяДата, МЕСЯЦ)
	|	И Закупки.Период < ДОБАВИТЬКДАТЕ(КОНЕЦПЕРИОДА(&ТекущаяДата, МЕСЯЦ), СЕКУНДА, 1)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Закупки.АналитикаУчетаНоменклатуры.Номенклатура КАК Номенклатура,
	|	ВТ_Наценка.Организация КАК Организация,
	|	ВТ_Наценка.СкладРеализации КАК СкладРеализации,
	|	ВТ_Наценка.Подразделение КАК Подразделение,
	|	Закупки.Стоимость / Закупки.Количество КАК Стоимость
	|ПОМЕСТИТЬ ВТ_ЗакупкиТекМесяцПодразделение
	|ИЗ
	|	РегистрНакопления.Закупки КАК Закупки
