// Преобразует параметры приказа в формат, пригодный для сериализации в JSON
//
// Параметры:
//  ПараметрыПриказа - Структура - исходные параметры с объектными типами:
//   * СписокКОзнакомлению - ТаблицаЗначений с колонкой ФизическоеЛицо
//   * ДатаНачалаДействия - Дата
//
// Возвращаемое значение:
//  Структура - параметры в сериализуемом формате (примитивные типы)
//
Функция ПреобразоватьПараметрыПриказаДляJSON(ПараметрыПриказа)
	
	Результат = Новый Структура;
	
	// Преобразуем Организацию в строку (UUID)
	Если ПараметрыПриказа.Свойство("Организация") 
		И ЗначениеЗаполнено(ПараметрыПриказа.Организация) Тогда
		
		Результат.Вставить("Организация", 
			Строка(ПараметрыПриказа.Организация.УникальныйИдентификатор()));
		
	Иначе
		
		Результат.Вставить("Организация", "");
		
	КонецЕсли;
	
	// Преобразуем Склад в строку (UUID)
	Если ПараметрыПриказа.Свойство("Склад") 
		И ЗначениеЗаполнено(ПараметрыПриказа.Склад) Тогда
		
		Результат.Вставить("Склад", 
			Строка(ПараметрыПриказа.Склад.УникальныйИдентификатор()));
		
	Иначе
		
		Результат.Вставить("Склад", "");
		
	КонецЕсли;
	
	// Сохраняем строковые поля как есть
	Если ПараметрыПриказа.Свойство("Тема") Тогда
		Результат.Вставить("Тема", ПараметрыПриказа.Тема);
	Иначе
		Результат.Вставить("Тема", "");
	КонецЕсли;
	
	Если ПараметрыПриказа.Свойство("Цель") Тогда
		Результат.Вставить("Цель", ПараметрыПриказа.Цель);
	Иначе
		Результат.Вставить("Цель", "");
	КонецЕсли;
	
	Если ПараметрыПриказа.Свойство("ГуидЕлмаОрганизации") Тогда
		Результат.Вставить("ГуидЕлмаОрганизации", ПараметрыПриказа.ГуидЕлмаОрганизации);
	Иначе
		Результат.Вставить("ГуидЕлмаОрганизации", "");
	КонецЕсли;
	
	// Преобразуем СписокКОзнакомлению (ТаблицаЗначений или Массив) в массив UID ЕЛМА
	МассивСпискаКОзнакомлению = Новый Массив;
	
	Если ПараметрыПриказа.Свойство("СписокКОзнакомлению") Тогда
		
		Если ТипЗнч(ПараметрыПриказа.СписокКОзнакомлению) = Тип("ТаблицаЗначений") Тогда
		
			Для Каждого Строка Из ПараметрыПриказа.СписокКОзнакомлению Цикл
				
				Если Строка.Свойство("ФизическоеЛицо") И ЗначениеЗаполнено(Строка.ФизическоеЛицо) Тогда
					
					UidЕЛМА = ПолучитьUidФизЛицаЕЛМА(Строка.ФизическоеЛицо);
					
					Если ЗначениеЗаполнено(UidЕЛМА) Тогда
						
						МассивСпискаКОзнакомлению.Добавить(UidЕЛМА);
						
					Иначе
						
						ЗаписатьЛог(СтрШаблон("Не найден UID ЕЛМА для физлица '%1' из списка к ознакомлению", 
							Строка.ФизическоеЛицо), УровеньЖурналаРегистрации.Предупреждение);
						
					КонецЕсли;
					
				КонецЕсли;
				
			КонецЦикла;
			
		ИначеЕсли ТипЗнч(ПараметрыПриказа.СписокКОзнакомлению) = Тип("Массив") Тогда
			
			Для Каждого Элемент Из ПараметрыПриказа.СписокКОзнакомлению Цикл
				
				Если Элемент.Свойство("ФизическоеЛицо") И ЗначениеЗаполнено(Элемент.ФизическоеЛицо) Тогда
					
					UidЕЛМА = ПолучитьUidФизЛицаЕЛМА(Элемент.ФизическоеЛицо);
					
					Если ЗначениеЗаполнено(UidЕЛМА) Тогда
						
						МассивСпискаКОзнакомлению.Добавить(UidЕЛМА);
						
					Иначе
						
						ЗаписатьЛог(СтрШаблон("Не найден UID ЕЛМА для физлица '%1' из списка к ознакомлению", 
							Элемент.ФизическоеЛицо), УровеньЖурналаРегистрации.Предупреждение);
						
					КонецЕсли;
					
				КонецЕсли;
				
			КонецЦикла;
			
		Иначе
			// Неподдерживаемый тип - пропускаем
			
		КонецЕсли;
		
	КонецЕсли;
	
	Результат.Вставить("СписокКОзнакомлению", МассивСпискаКОзнакомлению);
	
	// ДатаНачалаДействия преобразуем в строку ISO 8601
	Если ПараметрыПриказа.Свойство("ДатаНачалаДействия") 
		И ЗначениеЗаполнено(ПараметрыПриказа.ДатаНачалаДействия) Тогда
		
		Результат.Вставить("ДатаНачалаДействия", XMLСтрока(ПараметрыПриказа.ДатаНачалаДействия));
		
	Иначе
		
		Результат.Вставить("ДатаНачалаДействия", "");
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Преобразует параметры приказа из JSON-формата обратно в объектные типы
//
// Параметры:
//  СериализованныеПараметры - Структура - параметры в JSON-формате с примитивными типами:
//   * СписокКОзнакомлению - Массив строк (UUID)
//   * ДатаНачалаДействия - Строка (ISO 8601)
//
// Возвращаемое значение:
//  Структура - параметры с объектными типами:
//   * СписокКОзнакомлению - ТаблицаЗначений с колонкой ФизическоеЛицо
//   * ДатаНачалаДействия - Дата
//
Функция ПреобразоватьПараметрыПриказаИзJSON(СериализованныеПараметры)
	
	Результат = Новый Структура;
	
	// Преобразуем СписокКОзнакомлению из массива UID ЕЛМА в таблицу значений
	ТаблицаСпискаКОзнакомлению = Новый ТаблицаЗначений;
	ТаблицаСпискаКОзнакомлению.Колонки.Добавить("ФизическоеЛицо", Новый ОписаниеТипов("СправочникСсылка.ФизическиеЛица"));
	
	Если СериализованныеПараметры.Свойство("СписокКОзнакомлению") 
		И ТипЗнч(СериализованныеПараметры.СписокКОзнакомлению) = Тип("Массив") Тогда
		
		Для Каждого УИДСтрока Из СериализованныеПараметры.СписокКОзнакомлению Цикл
			
			Если НЕ ПустаяСтрока(УИДСтрока) Тогда
				
				// Попытка восстановить по UID ЕЛМА
				ФизЛицо = ПолучитьФизЛицоПоУИДЕЛМА(УИДСтрока);
				
				Если ЗначениеЗаполнено(ФизЛицо) Тогда
					
					НоваяСтрока = ТаблицаСпискаКОзнакомлению.Добавить();
					НоваяСтрока.ФизическоеЛицо = ФизЛицо;
					
				Иначе
					
					// Fallback: попытка восстановить по UUID 1С (для обратной совместимости)
					Попытка
						
						УникальныйИдентификатор = Новый УникальныйИдентификатор(УИДСтрока);
						Ссылка = Справочники.ФизическиеЛица.ПолучитьСсылку(УникальныйИдентификатор);
						
						НоваяСтрока = ТаблицаСпискаКОзнакомлению.Добавить();
						НоваяСтрока.ФизическоеЛицо = Ссылка;
						
						ЗаписатьЛог(СтрШаблон("Использован fallback для восстановления физлица из списка по UUID 1С '%1'", УИДСтрока), 
							УровеньЖурналаРегистрации.Предупреждение);
						
					Исключение
						
						// Пропускаем невалидные UID - просто не добавляем их в таблицу
						ЗаписатьЛог(СтрШаблон("Не удалось восстановить физлицо из списка к ознакомлению по UID '%1'", УИДСтрока), 
							УровеньЖурналаРегистрации.Предупреждение);
						
					КонецПопытки;
					
				КонецЕсли;
				
			КонецЕсли;
			
		КонецЦикла;
		
	КонецЕсли;
	
	Результат.Вставить("СписокКОзнакомлению", ТаблицаСпискаКОзнакомлению);
	
	// Преобразуем Организацию из UUID в ссылку
	Если СериализованныеПараметры.Свойство("Организация") Тогда
		
		UUIDСтрока = СериализованныеПараметры.Организация;
		
		Если НЕ ПустаяСтрока(UUIDСтрока) Тогда
			
			Попытка
				
				УникальныйИдентификатор = Новый УникальныйИдентификатор(UUIDСтрока);
				Ссылка = Справочники.Организации.ПолучитьСсылку(УникальныйИдентификатор);
				Результат.Вставить("Организация", Ссылка);
				
			Исключение
				
				Результат.Вставить("Организация", Справочники.Организации.ПустаяСсылка());
				
			КонецПопытки;
			
		Иначе
			
			Результат.Вставить("Организация", Справочники.Организации.ПустаяСсылка());
			
		КонецЕсли;
		
	КонецЕсли;
	
	// Преобразуем Склад из UUID в ссылку
	Если СериализованныеПараметры.Свойство("Склад") Тогда
		
		UUIDСтрока = СериализованныеПараметры.Склад;
		
		Если НЕ ПустаяСтрока(UUIDСтрока) Тогда
			
			Попытка
				
				УникальныйИдентификатор = Новый УникальныйИдентификатор(UUIDСтрока);
				Ссылка = Справочники.Склады.ПолучитьСсылку(УникальныйИдентификатор);
				Результат.Вставить("Склад", Ссылка);
				
			Исключение
				
				Результат.Вставить("Склад", Справочники.Склады.ПустаяСсылка());
				
			КонецПопытки;
			
		Иначе
			
			Результат.Вставить("Склад", Справочники.Склады.ПустаяСсылка());
			
		КонецЕсли;
		
	КонецЕсли;
	
	// Восстанавливаем строковые поля
	Если СериализованныеПараметры.Свойство("Тема") Тогда
		Результат.Вставить("Тема", СериализованныеПараметры.Тема);
	Иначе
		Результат.Вставить("Тема", "");
	КонецЕсли;
	
	Если СериализованныеПараметры.Свойство("Цель") Тогда
		Результат.Вставить("Цель", СериализованныеПараметры.Цель);
	Иначе
		Результат.Вставить("Цель", "");
	КонецЕсли;
	
	Если СериализованныеПараметры.Свойство("ГуидЕлмаОрганизации") Тогда
		Результат.Вставить("ГуидЕлмаОрганизации", СериализованныеПараметры.ГуидЕлмаОрганизации);
	Иначе
		Результат.Вставить("ГуидЕлмаОрганизации", "");
	КонецЕсли;
	
	// ДатаНачалаДействия преобразуем из строки ISO 8601 в дату
	Если СериализованныеПараметры.Свойство("ДатаНачалаДействия") Тогда
		
		ДатаСтрока = СериализованныеПараметры.ДатаНачалаДействия;
		
		Если НЕ ПустаяСтрока(ДатаСтрока) Тогда
			
			Попытка
				
				Результат.Вставить("ДатаНачалаДействия", XMLЗначение(Тип("Дата"), ДатаСтрока));
				
			Исключение
				
				Результат.Вставить("ДатаНачалаДействия", '00010101');
				
			КонецПопытки;
			
		Иначе
			
			Результат.Вставить("ДатаНачалаДействия", '00010101');
			
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Проверяет, требуется ли отправка документа в ЕЛМА
//
// Параметры:
//  Документ - ДокументОбъект.УстановкаЦенНоменклатуры
//
// Возвращаемое значение:
//  Булево - Истина если требуется отправка в ЕЛМА
//
Функция ТребуетсяОтправкаВЕЛМА(Документ) Экспорт
	
	// Проверяем, есть ли виды цен, привязанные к питУдаленныеКассы
	Если Документ.Товары.Количество() = 0 Тогда
		Возврат Ложь;
	КонецЕсли;
	
	// Получаем уникальные виды цен из документа
	МассивВидовЦен = Новый Массив;
	Для Каждого Строка Из Документ.ВидыЦен Цикл
		Если МассивВидовЦен.Найти(Строка.ВидЦены) = Неопределено Тогда
			МассивВидовЦен.Добавить(Строка.ВидЦены);
		КонецЕсли;
	КонецЦикла;
	
	// Проверяем наличие видов цен в плане обмена
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	питУдаленныеКассы.ВидЦен КАК ВидЦен,
		|	питУдаленныеКассы.Организация КАК Организация
		|ИЗ
		|	ПланОбмена.питУдаленныеКассы КАК питУдаленныеКассы
		|ГДЕ
		|	питУдаленныеКассы.ВидЦен В(&МассивВидовЦен)";
	
	Запрос.УстановитьПараметр("МассивВидовЦен", МассивВидовЦен);
	
	Результат = Запрос.Выполнить();
	
	Возврат НЕ Результат.Пустой();
	
КонецФункции

